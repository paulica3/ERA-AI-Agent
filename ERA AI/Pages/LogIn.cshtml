@page
@model LogInModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Efrim Roșca Asociații — Login</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png"/>
  <link rel="icon" href="/favicon.ico" sizes="any"/>
  <link rel="apple-touch-icon" href="/favicon-32.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="css/login.css">
</head>
<body>
<div class="page">

  <!-- Header -->
  <header>
    <div class="logo-mark">
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="0.5" y="0.5" width="47" height="47" stroke="#8b6914" stroke-width="1" fill="none"/>
        <line x1="0" y1="0" x2="7" y2="0"   stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="0" y1="0" x2="0" y2="7"   stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="48" y1="0"  x2="41" y2="0"  stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="48" y1="0"  x2="48" y2="7"  stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="0"  y1="48" x2="7"  y2="48" stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="0"  y1="48" x2="0"  y2="41" stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="48" y1="48" x2="41" y2="48" stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="48" y1="48" x2="48" y2="41" stroke="#c9a84c" stroke-width="1.2"/>
        <text x="25" y="23" font-family="Cormorant Garamond, serif" font-size="13" font-weight="500"
              fill="#8b6914" text-anchor="middle" letter-spacing="2">ERA</text>
        <line x1="10" y1="28" x2="38" y2="28" stroke="#c9a84c" stroke-width="0.6" opacity="0.6"/>
        <text x="25" y="39" font-family="Jost, sans-serif" font-size="8" font-weight="300"
              fill="#7a7060" text-anchor="middle" letter-spacing="4">AI</text>
      </svg>
    </div>
    <div class="header-text">
      <div class="firm-name">Efrim Roșca <span>&amp;</span> Asociații</div>
      <div class="firm-sub">Asistent Juridic AI</div>
    </div>
  </header>

  <!-- Main -->
  <main>
    <div class="login-card">

      <!-- Emblem -->
      <svg class="emblem" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="0.5" y="0.5" width="99" height="99" stroke="#8b6914" stroke-width="0.8" fill="none"/>
        <line x1="0" y1="0" x2="14" y2="0"    stroke="#c9a84c" stroke-width="1.5"/>
        <line x1="0" y1="0" x2="0"  y2="14"   stroke="#c9a84c" stroke-width="1.5"/>
        <line x1="100" y1="0"   x2="86"  y2="0"   stroke="#c9a84c" stroke-width="1.5"/>
        <line x1="100" y1="0"   x2="100" y2="14"  stroke="#c9a84c" stroke-width="1.5"/>
        <line x1="0"   y1="100" x2="14"  y2="100" stroke="#c9a84c" stroke-width="1.5"/>
        <line x1="0"   y1="100" x2="0"   y2="86"  stroke="#c9a84c" stroke-width="1.5"/>
        <line x1="100" y1="100" x2="86"  y2="100" stroke="#c9a84c" stroke-width="1.5"/>
        <line x1="100" y1="100" x2="100" y2="86"  stroke="#c9a84c" stroke-width="1.5"/>
        <text x="52" y="52" font-family="Cormorant Garamond, serif" font-size="28" font-weight="500"
              fill="#8b6914" text-anchor="middle" letter-spacing="5">ERA</text>
        <line x1="18" y1="59" x2="82" y2="59" stroke="#c9a84c" stroke-width="0.8" opacity="0.6"/>
        <text x="52" y="74" font-family="Jost, sans-serif" font-size="13" font-weight="300"
              fill="#7a7060" text-anchor="middle" letter-spacing="8">AI</text>
      </svg>

      <h1 class="card-title">Bine ați venit</h1>
      <p class="card-sub">Introduceți credențialele pentru a accesa platforma</p>

      <!-- Error -->
      <div class="error-msg" id="errorMsg">
        Adresa de email sau parola este incorectă.
      </div>

      <!-- Form -->
      <div class="form-group">
        <label for="email">Adresă de email</label>
        <input type="email" id="email" placeholder="nume@era.md" autocomplete="email"/>
      </div>

      <div class="form-group">
        <label for="password">Parolă</label>
        <input type="password" id="password" placeholder="*******" autocomplete="current-password"
               onkeydown="if(event.key==='Enter') handleLogin()"/>
        <div class="forgot"><a href="#">Ați uitat parola?</a></div>
      </div>

      <button class="btn-login" onclick="handleLogin()">Autentificare</button>

    </div>
  </main>

  <!-- Footer -->
  <footer>
    <div class="footer-left">Efrim Roșca <span>&amp;</span> Asociații &nbsp;·&nbsp; ERA AI</div>
    <div class="footer-right">
      Chișinău, Moldova
      <span class="footer-sep"></span>
      © 2025
    </div>
  </footer>

</div>

<script>
  function handleLogin() {
    const email    = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value;
    const errorMsg = document.getElementById('errorMsg');

    if (!email || !password) {
      errorMsg.textContent = 'Vă rugăm completați toate câmpurile.';
      errorMsg.classList.add('visible');
      return;
    }
    else{
      window.location.href = "/";
    }

    // Replace this with your real auth logic / form post
    errorMsg.classList.remove('visible');
    console.log('Login attempt:', email);
  }
</script>

</body>
</html>