  // ── /memory command ───────────────────────────────────────────────
  async function saveMemory(text) {
    // Show a pending note while Claude processes the text.
    const note = document.createElement('div');
    note.className = 'memory-note';
    note.textContent = 'Se extrag regulile...';
    messagesEl.appendChild(note);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    try {
      const r = await fetch('/api/memory', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text })
      });
      if (requireAuth(r)) return;
      if (r.ok) {
        note.innerHTML = '<strong style="color:var(--gold);font-style:normal; font-size: 0.7rem;">Reguli salvate!</strong><br>';
      } else {
        note.textContent = 'Eroare la salvarea memoriei.';
        note.style.color = 'var(--red-accent)';
      }
    } catch {
      note.textContent = 'Nu s-a putut contacta serverul.';
      note.style.color = 'var(--red-accent)';
    }
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  // ── Send ──────────────────────────────────────────────────────────
  async function sendMessage() {
    const text = inputEl.value.trim();
    if (!text) return;

    // /memory command: save rule to profile, don't send as chat message
    if (text.startsWith('/memory ')) {
      const rule = text.slice('/memory '.length).trim();
      inputEl.value = '';
      inputEl.style.height = 'auto';
      document.getElementById('charCount').textContent = '0';
      if (rule) { hideWelcome(); await saveMemory(rule); }
      return;
    }

    hideWelcome();

    const isNew = !currentId;

    renderMessage('user', text);
    inputEl.value = '';
    inputEl.style.height = 'auto';
    document.getElementById('charCount').textContent = '0';

    showTyping();

    try {
      // Chat runs server-side: Python loads the profile, injects it, calls the
      // model, and persists both messages. We just send the new turn + the
      // conversation id (null for a new conversation).
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, conversation_id: currentId })
      });

      removeTyping();

      if (requireAuth(response)) return;

      if (!response.ok) {
        renderMessage('assistant', 'Ne cerem scuze, a apărut o eroare. Vă rugăm să încercați din nou.');
        return;
      }

      const data = await response.json();
      const fullText = (data.reply || '').trim();

      const bubble = appendStreamingBubble();
      bubble.innerHTML = marked.parse(fullText || 'Ne cerem scuze, nu am primit un răspuns.');
      messagesEl.scrollTop = messagesEl.scrollHeight;

      // Adopt the server's conversation id and refresh the sidebar.
      currentId = data.conversation_id;
      if (isNew) {
        conversations.unshift({ id: currentId, title: data.title || '…', updated_at: new Date().toISOString() });
        renderSidebar();
        upgradeTitle(currentId, text, fullText);
      }
    } catch {
      removeTyping();
      renderMessage('assistant', 'Ne cerem scuze, a apărut o eroare. Vă rugăm să încercați din nou.');
    }
  }

