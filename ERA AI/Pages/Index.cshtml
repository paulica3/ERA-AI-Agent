<script>
  // ── DOM refs ──────────────────────────────────────────────────────
  const messagesEl = document.getElementById('messages');
  const inputEl    = document.getElementById('userInput');
  let welcomeVisible = true;

  // ── Conversation store (persisted in localStorage) ────────────────
  // Shape: { id: string, title: string, messages: {role, content}[] }[]
  let conversations = JSON.parse(localStorage.getItem('era_convs') || '[]');
  let currentId = null;

  function save() {
    localStorage.setItem('era_convs', JSON.stringify(conversations));
  }

  function getCurrent() {
    return conversations.find(c => c.id === currentId) || null;
  }

  // ── Sidebar ───────────────────────────────────────────────────────
  function renderSidebar() {
    const list = document.getElementById('sidebarList');
    list.innerHTML = '';

    if (conversations.length === 0) {
      list.innerHTML = '<div class="sidebar-empty">Nicio conversație încă</div>';
      return;
    }

    // Most recent first
    conversations.slice().reverse().forEach(conv => {
      const item = document.createElement('div');
      item.className = 'conv-item' + (conv.id === currentId ? ' active' : '');
      item.dataset.id = conv.id;
      item.innerHTML = `
        <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke-linejoin="round"/></svg>
        <span>${esc(conv.title)}</span>
        <button class="conv-delete" title="Șterge conversația">✕</button>`;
      item.onclick = () => loadConversation(conv.id);
      item.querySelector('.conv-delete').onclick = (e) => {
        e.stopPropagation();
        deleteConversation(conv.id);
      };
      list.appendChild(item);
    });
  }

  function deleteConversation(id) {
    conversations = conversations.filter(c => c.id !== id);
    if (currentId === id) {
      currentId = null;
      messagesEl.innerHTML = '';
      messagesEl.appendChild(buildWelcome());
      welcomeVisible = true;
    }
    save();
    renderSidebar();
  }

  function esc(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // ── Conversation management ───────────────────────────────────────
  function newConversation() {
    currentId = null;
    welcomeVisible = true;
    messagesEl.innerHTML = '';
    messagesEl.appendChild(buildWelcome());
    renderSidebar();
    inputEl.focus();
  }

  function loadConversation(id) {
    const conv = conversations.find(c => c.id === id);
    if (!conv) return;
    currentId = id;
    welcomeVisible = false;
    messagesEl.innerHTML = '';
    conv.messages.forEach(m => renderMessage(m.role, m.content));
    renderSidebar();
  }

  function startConversation(firstMessage) {
    const id = crypto.randomUUID ? crypto.randomUUID() : Date.now().toString();
    const conv = { id, title: '…', messages: [] };
    conversations.push(conv);
    currentId = id;
    save();
    renderSidebar();
    return conv;
  }

  // Called after the first bot reply — uses both Q and A for a better title
  async function generateTitle(conv, userMessage, botReply) {
    const fallback = userMessage.length > 35 ? userMessage.slice(0, 35) + '…' : userMessage;
    try {
      const r = await fetch('/api/title', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: userMessage, reply: botReply })
      });
      const data = await r.json();
      // Guard: only use the returned title if it looks like a real title (short, no error keywords)
      const raw = data.title || '';
      const title = (raw.length > 0 && raw.length <= 50) ? raw : fallback;
      conv.title = title;
      save();
      animateTitle(conv.id, title);
    } catch {
      conv.title = fallback;
      save();
      animateTitle(conv.id, fallback);
    }
  }

  // Typewriter effect: writes the title letter by letter into the sidebar item
  function animateTitle(convId, title) {
    renderSidebar(); // rebuild list with final data, then overwrite the one span
    const item = document.querySelector(`.conv-item[data-id="${convId}"]`);
    if (!item) return;
    const span = item.querySelector('span');
    span.textContent = '';
    let i = 0;
    const tick = setInterval(() => {
      span.textContent += title[i++];
      if (i >= title.length) clearInterval(tick);
    }, 35);
  }

  function buildWelcome() {
    const div = document.createElement('div');
    div.className = 'welcome';
    div.id = 'welcome';
    div.innerHTML = `
      <div class="welcome-emblem">
        <svg viewBox="0 0 100 100" fill="none">
          <rect x="0.5" y="0.5" width="99" height="99" stroke="#9B2D3A" stroke-width="0.8" fill="none"/>
          <line x1="0" y1="0" x2="14" y2="0" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="0" y1="0" x2="0" y2="14" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="100" y1="0" x2="86" y2="0" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="100" y1="0" x2="100" y2="14" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="0" y1="100" x2="14" y2="100" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="0" y1="100" x2="0" y2="86" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="100" y1="100" x2="86" y2="100" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="100" y1="100" x2="100" y2="86" stroke="#C4556A" stroke-width="1.5"/>
          <text x="52" y="48" font-family="Cormorant Garamond, serif" font-size="28" font-weight="500"
                fill="#9B2D3A" text-anchor="middle" letter-spacing="5">ERA</text>
          <line x1="18" y1="57" x2="82" y2="57" stroke="#C4556A" stroke-width="0.8" opacity="0.6"/>
          <text x="54" y="72" font-family="Jost, sans-serif" font-size="13" font-weight="300"
                fill="#7a7060" text-anchor="middle" letter-spacing="8">AI</text>
        </svg>
      </div>
      <h1>Bine ați venit<br/>la asistentul dumneavoastră</h1>
      <p>Sunt aici să vă ajut cu eficiența în activitatea juridică — de la redactarea documentelor până la cercetare și organizare.</p>
      <div class="suggestions">
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Redactează un contract</button>
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Rezumă un document</button>
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Cercetare juridică</button>
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Redactează o scrisoare</button>
      </div>`;
    return div;
  }

  // ── Rendering helpers ─────────────────────────────────────────────
  const _avatarSvg = `<svg viewBox="0 0 32 32" width="18" height="18" fill="none">
    <circle cx="16" cy="16" r="4.5" fill="#9B2D3A" opacity="0.15"/>
    <circle cx="16" cy="16" r="2.5" fill="#9B2D3A"/>
    <circle cx="16" cy="7"  r="1.8" fill="#C4556A"/>
    <circle cx="25" cy="16" r="1.8" fill="#C4556A"/>
    <circle cx="16" cy="25" r="1.8" fill="#C4556A"/>
    <circle cx="7"  cy="16" r="1.8" fill="#C4556A"/>
    <line x1="16" y1="13.5" x2="16" y2="8.8"   stroke="#9B2D3A" stroke-width="0.6" opacity="0.3"/>
    <line x1="18.5" y1="16" x2="23.2" y2="16"  stroke="#9B2D3A" stroke-width="0.6" opacity="0.3"/>
    <line x1="16" y1="18.5" x2="16" y2="23.2"  stroke="#9B2D3A" stroke-width="0.6" opacity="0.3"/>
    <line x1="13.5" y1="16" x2="8.8" y2="16"   stroke="#9B2D3A" stroke-width="0.6" opacity="0.3"/>
  </svg>`;

  function renderMessage(role, text) {
    const isUser = role === 'user';
    const msg = document.createElement('div');
    msg.className = `msg ${role}`;

    const avatar = document.createElement('div');
    avatar.className = 'msg-avatar';
    avatar.innerHTML = isUser ? '<span>DV</span>' : _avatarSvg;

    const body = document.createElement('div');
    body.className = 'msg-body';

    const sender = document.createElement('div');
    sender.className = 'msg-sender';
    sender.textContent = isUser ? 'Dumneavoastră' : 'ERA AI · Efrim Roșca & Asociații';

    const bubble = document.createElement('div');
    bubble.className = 'msg-bubble';
    bubble.innerHTML = isUser ? '' : marked.parse(text);
    if (isUser) bubble.textContent = text;

    body.appendChild(sender);
    body.appendChild(bubble);
    msg.appendChild(avatar);
    msg.appendChild(body);
    messagesEl.appendChild(msg);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  // Creates an empty assistant bubble and returns the inner <div> to stream into
  function appendStreamingBubble() {
    const msg = document.createElement('div');
    msg.className = 'msg assistant';
    msg.innerHTML = `
      <div class="msg-avatar">${_avatarSvg}</div>
      <div class="msg-body">
        <div class="msg-sender">ERA AI · Efrim Roșca &amp; Asociații</div>
        <div class="msg-bubble"></div>
      </div>`;
    messagesEl.appendChild(msg);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return msg.querySelector('.msg-bubble');
  }

  // Generic SSE reader — calls onChunk(parsedObject) for every data line
  async function readStream(response, onChunk) {
    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, { stream: true });
      const lines = buffer.split('\n');
      buffer = lines.pop() ?? '';
      for (const line of lines) {
        if (!line.startsWith('data: ')) continue;
        const data = line.slice(6).trim();
        if (!data || data === '[DONE]') continue;
        try { onChunk(JSON.parse(data)); } catch {}
      }
    }
  }

  function showTyping() {
    const wrap = document.createElement('div');
    wrap.className = 'msg assistant';
    wrap.id = 'typingWrap';
    wrap.innerHTML = `
      <div class="msg-avatar">
        <svg viewBox="0 0 32 32" width="18" height="18" fill="none">
          <circle cx="16" cy="16" r="4.5" fill="#9B2D3A" opacity="0.15"/>
          <circle cx="16" cy="16" r="2.5" fill="#9B2D3A"/>
          <circle cx="16" cy="7"  r="1.8" fill="#C4556A"/>
          <circle cx="25" cy="16" r="1.8" fill="#C4556A"/>
          <circle cx="16" cy="25" r="1.8" fill="#C4556A"/>
          <circle cx="7"  cy="16" r="1.8" fill="#C4556A"/>
        </svg>
      </div>
      <div class="msg-body">
        <div class="msg-sender">ERA AI · Efrim Roșca & Asociații</div>
        <div class="typing-indicator">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>
      </div>`;
    messagesEl.appendChild(wrap);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function removeTyping() {
    const el = document.getElementById('typingWrap');
    if (el) el.remove();
  }

  // ── Input helpers ─────────────────────────────────────────────────
  function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 120) + 'px';
  }

  function updateCharCount(el) {
    document.getElementById('charCount').textContent = el.value.length;
  }

  function handleKey(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  }

  function sendSuggestion(btn) {
    inputEl.value = btn.textContent;
    sendMessage();
  }

  function hideWelcome() {
    if (!welcomeVisible) return;
    const el = document.getElementById('welcome');
    if (el) {
      el.style.transition = 'opacity 0.25s ease';
      el.style.opacity = '0';
      setTimeout(() => el.remove(), 250);
    }
    welcomeVisible = false;
  }

  // ── Send ──────────────────────────────────────────────────────────
  async function sendMessage() {
    const text = inputEl.value.trim();
    if (!text) return;

    hideWelcome();

    const isNew = !currentId;
    if (isNew) startConversation(text);

    const conv = getCurrent();
    conv.messages.push({ role: 'user', content: text });
    save();

    renderMessage('user', text);
    inputEl.value = '';
    inputEl.style.height = 'auto';
    document.getElementById('charCount').textContent = '0';

    showTyping();

    try {
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: conv.messages })
      });

      removeTyping();

      if (!response.ok || !response.body) {
        renderMessage('assistant', 'Ne cerem scuze, a apărut o eroare. Vă rugăm să încercați din nou.');
        return;
      }

      const bubble = appendStreamingBubble();
      let fullText = '';
      let displayIdx = 0;
      let streamDone = false;

      // Plain-text typewriter: no markdown mid-stream = zero layout reflow = silky smooth.
      // rAF drains the buffer at a steady pace; markdown renders once at the very end.
      const animFinished = new Promise(resolve => {
        function tick() {
          const remaining = fullText.length - displayIdx;
          if (remaining > 0) {
            // While streaming keep pace with Claude; once done, flush quickly
            displayIdx += streamDone ? Math.min(remaining, 6) : Math.min(remaining, 3);
            bubble.textContent = fullText.slice(0, displayIdx);
            messagesEl.scrollTop = messagesEl.scrollHeight;
          }
          if (streamDone && displayIdx >= fullText.length) resolve();
          else requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      });

      await readStream(response, (evt) => {
        if (evt.delta?.text) fullText += evt.delta.text;
      });
      streamDone = true;
      await animFinished;

      // Swap plain text for fully rendered markdown
      bubble.innerHTML = marked.parse(fullText || 'Ne cerem scuze, nu am primit un răspuns.');
      messagesEl.scrollTop = messagesEl.scrollHeight;

      conv.messages.push({ role: 'assistant', content: fullText });
      save();

      if (isNew) generateTitle(conv, text, fullText);
    } catch {
      removeTyping();
      renderMessage('assistant', 'Ne cerem scuze, a apărut o eroare. Vă rugăm să încercați din nou.');
    }
  }

  // ── Sidebar toggle ────────────────────────────────────────────────
  function isMobile() { return window.innerWidth <= 768; }

  function toggleSidebar() {
    if (isMobile()) {
      closeSidebar();
    } else {
      document.getElementById('sidebar').classList.toggle('collapsed');
    }
  }

  function openSidebar() {
    document.getElementById('sidebar').classList.add('open');
    document.getElementById('sidebarOverlay').classList.add('visible');
  }

  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('visible');
  }

  // ── Tab switching ─────────────────────────────────────────────────
  function switchTab(tab) {
    const isChat    = tab === 'chat';
    const isAnalyze = tab === 'analyze';
    const isDraft   = tab === 'draft';
    const isInvoice = tab === 'invoice';
    const isOffer   = tab === 'offer';
    const isInstr   = tab === 'instructions';
    document.getElementById('messages').style.display          = isChat    ? '' : 'none';
    document.getElementById('inputArea').style.display         = isChat    ? '' : 'none';
    document.getElementById('analyzePanel').style.display      = isAnalyze ? '' : 'none';
    document.getElementById('draftPanel').style.display        = isDraft   ? '' : 'none';
    document.getElementById('invoicePanel').style.display      = isInvoice ? '' : 'none';
    document.getElementById('offerPanel').style.display        = isOffer   ? '' : 'none';
    document.getElementById('instructionsPanel').style.display = isInstr   ? '' : 'none';
    document.getElementById('tabChat').classList.toggle('active', isChat);
    document.getElementById('tabAnalyze').classList.toggle('active', isAnalyze);
    document.getElementById('tabDraft').classList.toggle('active', isDraft);
    document.getElementById('tabInvoice').classList.toggle('active', isInvoice);
    document.getElementById('tabOffer').classList.toggle('active', isOffer);
    document.getElementById('tabInstructions').classList.toggle('active', isInstr);
    if (isInstr) loadInstructions();
  }

  // ── Document analysis ─────────────────────────────────────────────
  function handleFileSelect(input) {
    const file = input.files[0];
    if (!file) return;
    document.getElementById('fileSelectedName').textContent = file.name;
    document.getElementById('fileSelected').style.display = 'flex';
    document.getElementById('analyzeBtn').disabled = false;
  }

  function handleDrop(event) {
    event.preventDefault();
    document.getElementById('uploadZone').classList.remove('drag-over');
    const file = event.dataTransfer.files[0];
    if (!file) return;
    const dt = new DataTransfer();
    dt.items.add(file);
    document.getElementById('fileInput').files = dt.files;
    handleFileSelect(document.getElementById('fileInput'));
  }

  async function analyzeDocument() {
    const fileInput = document.getElementById('fileInput');
    const file = fileInput.files[0];
    if (!file) return;

    const btn = document.getElementById('analyzeBtn');
    btn.disabled = true;

    const resultsEl = document.getElementById('analysisResults');
    resultsEl.style.display = 'none';
    resultsEl.innerHTML = '';

    const loadingEl = document.getElementById('analyzeLoading');
    const loadingText = loadingEl.querySelector('.analyze-loading-text');
    loadingText.textContent = 'Se pregătește documentul...';
    loadingEl.style.display = 'flex';

    try {
      const formData = new FormData();
      formData.append('file', file);

      const response = await fetch('/api/analyze', { method: 'POST', body: formData });

      if (!response.ok || !response.body) {
        let msg = 'Eroare server';
        try { const err = await response.json(); msg = err.error || err.detail || msg; } catch {}
        throw new Error(msg);
      }

      let streamError = null;

      await readStream(response, (evt) => {
        if (evt.status) {
          // Real progress update from the server
          loadingText.textContent = evt.status;
        } else if (evt.error) {
          streamError = evt.error;
        } else if (evt.result) {
          // Final result — render the two cards
          loadingEl.style.display = 'none';
          const data = evt.result;
          resultsEl.innerHTML = `
            <div class="analysis-card">
              <div class="analysis-card-header">Rezumat</div>
              <div class="analysis-card-body">${marked.parse(data.summary)}</div>
            </div>
            <div class="analysis-card">
              <div class="analysis-card-header">Clauze &amp; Riscuri</div>
              <div class="analysis-card-body">${marked.parse(data.clauses)}</div>
            </div>`;
          resultsEl.style.display = 'flex';
        }
      });

      if (streamError) throw new Error(streamError);

    } catch (e) {
      loadingEl.style.display = 'none';
      resultsEl.innerHTML = `<div class="analysis-card"><div class="analysis-card-body" style="color:var(--red-accent)">Eroare la analizarea documentului: ${e.message}</div></div>`;
      resultsEl.style.display = 'flex';
    } finally {
      btn.disabled = false;
    }
  }

  // ── Contract drafting ─────────────────────────────────────────────
  let lastDraftBlob = null;
  let lastDraftFilename = 'contract.docx';

  async function draftContract() {
    const clientName = document.getElementById('clientName').value.trim();
    const scope      = document.getElementById('contractScope').value.trim();

    if (!clientName || !scope) {
      alert('Completați câmpurile obligatorii: Denumire Client și Descrierea cazului.');
      return;
    }

    const btn = document.getElementById('draftBtn');
    btn.disabled = true;
    document.getElementById('draftLoading').style.display  = 'flex';
    document.getElementById('draftSuccess').style.display  = 'none';
    document.getElementById('draftError').style.display    = 'none';
    document.getElementById('draftError').textContent      = '';

    try {
      const payload = {
        clientName:      clientName,
        clientType:      document.getElementById('clientType').value,
        clientIdno:      document.getElementById('clientIdno').value.trim(),
        clientAddress:   document.getElementById('clientAddress').value.trim(),
        clientRep:       document.getElementById('clientRep').value.trim(),
        clientRepRole:   document.getElementById('clientRepRole').value.trim(),
        scope:           scope,
        services:        document.getElementById('contractServices').value.trim(),
        fees:            document.getElementById('contractFees').value.trim(),
        duration:        document.getElementById('contractDuration').value.trim(),
        contractNumber:  document.getElementById('contractNumber').value.trim(),
      };

      const response = await fetch('/api/draft-contract', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        let msg = 'Eroare server';
        try { const err = await response.json(); msg = err.error || err.detail || msg; } catch {}
        throw new Error(msg);
      }

      lastDraftBlob = await response.blob();
      lastDraftFilename = `Contract_${clientName.replace(/\s+/g, '_')}.docx`;

      triggerDownload(lastDraftBlob, lastDraftFilename);

      document.getElementById('draftDownloadBtn').onclick = () => triggerDownload(lastDraftBlob, lastDraftFilename);
      document.getElementById('draftSuccess').style.display = 'flex';
    } catch (e) {
      const errEl = document.getElementById('draftError');
      errEl.textContent = `Eroare la redactarea contractului: ${e.message}`;
      errEl.style.display = 'block';
    } finally {
      document.getElementById('draftLoading').style.display = 'none';
      btn.disabled = false;
    }
  }

  function triggerDownload(blob, filename) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function resetDraft() {
    lastDraftBlob = null;
    document.getElementById('draftSuccess').style.display = 'none';
    document.getElementById('draftError').style.display   = 'none';
    ['clientName','clientIdno','clientAddress','clientRep','clientRepRole',
     'contractScope','contractServices','contractFees','contractDuration','contractNumber']
      .forEach(id => { document.getElementById(id).value = ''; });
  }

  // ── Invoice drafting ──────────────────────────────────────────────
  let lastInvoiceBlob = null;
  let lastInvoiceFilename = 'invoice.docx';

  // Pre-fill today's date on load
  (function() {
    const d = new Date();
    const months = ['January','February','March','April','May','June',
                    'July','August','September','October','November','December'];
    document.getElementById('invDate').value = `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
  })();

  async function draftInvoice() {
    const company = document.getElementById('invCompany').value.trim();
    const fee     = document.getElementById('invFee').value.trim();
    if (!company || !fee) {
      alert('Completați câmpurile obligatorii: Denumire companie și Onorariu legal.');
      return;
    }

    const btn = document.getElementById('invoiceBtn');
    btn.disabled = true;
    document.getElementById('invoiceLoading').style.display = 'flex';
    document.getElementById('invoiceSuccess').style.display = 'none';
    document.getElementById('invoiceError').style.display   = 'none';

    try {
      const payload = {
        date:               document.getElementById('invDate').value.trim(),
        companyName:        company,
        legalAddress:       document.getElementById('invAddress').value.trim(),
        clientIban:         document.getElementById('invIban').value.trim(),
        regNo:              document.getElementById('invRegNo').value.trim(),
        vatNo:              document.getElementById('invVatNo').value.trim(),
        invoiceNumber:      document.getElementById('invNumber').value.trim(),
        contractRef:        document.getElementById('invContractRef').value.trim(),
        serviceDescription: document.getElementById('invServiceDesc').value.trim(),
        legalFee:           fee,
        currency:           document.getElementById('invCurrency').value,
        expensesText:       document.getElementById('invExpenses').value.trim(),
        partnerName:        document.getElementById('invPartner').value.trim(),
        partnerTitle:       document.getElementById('invPartnerTitle').value.trim(),
        partnerEmail:       document.getElementById('invPartnerEmail').value.trim(),
      };

      const response = await fetch('/api/draft-invoice', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        let msg = 'Eroare server';
        try { const err = await response.json(); msg = err.error || err.detail || msg; } catch {}
        throw new Error(msg);
      }

      lastInvoiceBlob = await response.blob();
      lastInvoiceFilename = `Invoice_${company.replace(/\s+/g, '_')}.docx`;
      triggerDownload(lastInvoiceBlob, lastInvoiceFilename);

      document.getElementById('invoiceDownloadBtn').onclick = () => triggerDownload(lastInvoiceBlob, lastInvoiceFilename);
      document.getElementById('invoiceSuccess').style.display = 'flex';
    } catch (e) {
      const errEl = document.getElementById('invoiceError');
      errEl.textContent = `Eroare la generarea facturii: ${e.message}`;
      errEl.style.display = 'block';
    } finally {
      document.getElementById('invoiceLoading').style.display = 'none';
      btn.disabled = false;
    }
  }

  function resetInvoice() {
    lastInvoiceBlob = null;
    document.getElementById('invoiceSuccess').style.display = 'none';
    document.getElementById('invoiceError').style.display   = 'none';
    ['invCompany','invAddress','invIban','invRegNo','invVatNo',
     'invNumber','invContractRef','invServiceDesc','invFee','invExpenses']
      .forEach(id => { document.getElementById(id).value = ''; });
    // Re-fill today's date
    const d = new Date();
    const months = ['January','February','March','April','May','June',
                    'July','August','September','October','November','December'];
    document.getElementById('invDate').value = `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
  }

  // ── Offer generation ──────────────────────────────────────────────
  let lastOfferBlob = null;
  let lastOfferFilename = 'oferta.pptx';

  async function generateOffer() {
    const client     = document.getElementById('offClient').value.trim();
    const salutation = document.getElementById('offSalutation').value.trim();
    const introText  = document.getElementById('offIntro').value.trim();

    if (!client || !salutation || !introText) {
      alert('Completați câmpurile obligatorii: Denumire client, Formulă de adresare și Context tranzacție.');
      return;
    }

    const fmt = document.getElementById('offFormat').value;

    const btn = document.getElementById('offerBtn');
    btn.disabled = true;
    document.getElementById('offerLoading').style.display = 'flex';
    document.getElementById('offerSuccess').style.display = 'none';
    document.getElementById('offerError').style.display   = 'none';

    try {
      const payload = {
        clientName:         client,
        date:               document.getElementById('offDate').value.trim(),
        addresseeSalutation: salutation,
        addresseeBlock:     document.getElementById('offAddressee').value.trim(),
        introText:          introText,
        composeIntro:       document.getElementById('offCompose').checked,
        feeText:            document.getElementById('offFees').value.trim(),
        signatoryName:      document.getElementById('offSignName').value.trim(),
        signatoryTitle:     document.getElementById('offSignTitle').value.trim(),
        lang:               document.getElementById('offLang').value,
        reformatFees:       document.getElementById('offReformat').checked,
        format:             fmt,
      };

      const response = await fetch('/api/generate-custom-offer', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        let msg = 'Eroare server';
        try { const err = await response.json(); msg = err.error || err.detail || msg; } catch {}
        throw new Error(msg);
      }

      lastOfferBlob = await response.blob();
      lastOfferFilename = `Oferta_${client.replace(/\s+/g, '_')}.${fmt}`;
      triggerDownload(lastOfferBlob, lastOfferFilename);

      document.getElementById('offerDownloadBtn').onclick = () => triggerDownload(lastOfferBlob, lastOfferFilename);
      document.getElementById('offerSuccess').style.display = 'flex';
    } catch (e) {
      const errEl = document.getElementById('offerError');
      errEl.textContent = `Eroare la generarea ofertei: ${e.message}`;
      errEl.style.display = 'block';
    } finally {
      document.getElementById('offerLoading').style.display = 'none';
      btn.disabled = false;
    }
  }

  function resetOffer() {
    lastOfferBlob = null;
    document.getElementById('offerSuccess').style.display = 'none';
    document.getElementById('offerError').style.display   = 'none';
    ['offClient','offDate','offSalutation','offAddressee','offIntro','offFees']
      .forEach(id => { document.getElementById(id).value = ''; });
  }

  // ── Custom chat instructions ──────────────────────────────────────
  let instructionsLoaded = false;

  async function loadInstructions() {
    if (instructionsLoaded) return;   // load once per page session
    try {
      const r = await fetch('/api/chat-instructions');
      if (!r.ok) return;
      const data = await r.json();
      document.getElementById('instrText').value = data.instructions || '';
      instructionsLoaded = true;
    } catch {}
  }

  async function saveInstructions() {
    const btn = document.getElementById('instrSaveBtn');
    const text = document.getElementById('instrText').value;
    btn.disabled = true;
    document.getElementById('instrSuccess').style.display = 'none';
    document.getElementById('instrError').style.display   = 'none';
    try {
      const r = await fetch('/api/chat-instructions', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ instructions: text })
      });
      if (!r.ok) {
        let msg = 'Eroare server';
        try { const err = await r.json(); msg = err.error || err.detail || msg; } catch {}
        throw new Error(msg);
      }
      const data = await r.json();
      document.getElementById('instrText').value = data.instructions || '';
      const ok = document.getElementById('instrSuccess');
      ok.style.display = 'flex';
      setTimeout(() => { ok.style.display = 'none'; }, 2500);
    } catch (e) {
      const errEl = document.getElementById('instrError');
      errEl.textContent = `Eroare la salvarea instrucțiunilor: ${e.message}`;
      errEl.style.display = 'block';
    } finally {
      btn.disabled = false;
    }
  }

  // ── Init ──────────────────────────────────────────────────────────
  renderSidebar();
</script>

</body>
</html>
