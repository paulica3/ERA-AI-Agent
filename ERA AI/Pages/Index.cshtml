  async function analyzeDocument() {
    const fileInput = document.getElementById('fileInput');
    const file = fileInput.files[0];
    if (!file) return;

    const btn = document.getElementById('analyzeBtn');
    btn.disabled = true;

    const resultsEl = document.getElementById('analysisResults');
    resultsEl.style.display = 'none';
    resultsEl.innerHTML = '';

    const loadingEl = document.getElementById('analyzeLoading');
    const loadingText = loadingEl.querySelector('.analyze-loading-text');
    loadingText.textContent = 'Se pregătește documentul...';
    loadingEl.style.display = 'flex';

    try {
      const formData = new FormData();
      formData.append('file', file);

      const response = await fetch('/api/analyze', { method: 'POST', body: formData });

      if (!response.ok || !response.body) {
        let msg = 'Eroare server';
        try { const err = await response.json(); msg = err.error || err.detail || msg; } catch {}
        throw new Error(msg);
      }

      let streamError = null;

      await readStream(response, (evt) => {
        if (evt.status) {
          // Real progress update from the server
          loadingText.textContent = evt.status;
        } else if (evt.error) {
          streamError = evt.error;
        } else if (evt.result) {
          // Final result — render the two cards
          loadingEl.style.display = 'none';
          const data = evt.result;
          resultsEl.innerHTML = `
            <div class="analysis-card">
              <div class="analysis-card-header">Rezumat</div>
              <div class="analysis-card-body">${marked.parse(data.summary)}</div>
            </div>
            <div class="analysis-card">
              <div class="analysis-card-header">Clauze &amp; Riscuri</div>
              <div class="analysis-card-body">${marked.parse(data.clauses)}</div>
            </div>`;
          resultsEl.style.display = 'flex';
        }
      });

      if (streamError) throw new Error(streamError);

    } catch (e) {
      loadingEl.style.display = 'none';
      resultsEl.innerHTML = `<div class="analysis-card"><div class="analysis-card-body" style="color:var(--red-accent)">Eroare la analizarea documentului: ${e.message}</div></div>`;
      resultsEl.style.display = 'flex';
    } finally {
      btn.disabled = false;
    }
  }

