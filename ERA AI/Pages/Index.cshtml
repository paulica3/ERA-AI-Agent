<script>
  // ── DOM refs ──────────────────────────────────────────────────────
  const messagesEl = document.getElementById('messages');
  const inputEl    = document.getElementById('userInput');
  let welcomeVisible = true;

  // ── Conversation store (server-side, scoped to the logged-in user) ─
  // Conversations and messages live in the database. The browser keeps only a
  // lightweight list [{ id, title, updated_at }] for the sidebar.
  let conversations = [];
  let currentId = null;

  // Redirect to login if the session cookie expired / is missing.
  function requireAuth(resp) {
    if (resp.status === 401) { window.location.href = '/LogIn'; return true; }
    return false;
  }

  async function loadConversations() {
    try {
      const r = await fetch('/api/conversations');
      if (requireAuth(r)) return;
      if (!r.ok) return;
      const data = await r.json();
      conversations = data.conversations || [];
      renderSidebar();
    } catch {}
  }

  // ── Sidebar ───────────────────────────────────────────────────────
  function renderSidebar() {
    const list = document.getElementById('sidebarList');
    list.innerHTML = '';

    if (conversations.length === 0) {
      list.innerHTML = '<div class="sidebar-empty">Nicio conversație încă</div>';
      return;
    }

    // Server returns them ordered by updated_at desc already.
    conversations.forEach(conv => {
      const item = document.createElement('div');
      item.className = 'conv-item' + (conv.id === currentId ? ' active' : '');
      item.dataset.id = conv.id;
      item.innerHTML = `
        <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke-linejoin="round"/></svg>
        <span>${esc(conv.title)}</span>
        <button class="conv-delete" title="Șterge conversația">✕</button>`;
      item.onclick = () => loadConversation(conv.id);
      item.querySelector('.conv-delete').onclick = (e) => {
        e.stopPropagation();
        deleteConversation(conv.id);
      };
      list.appendChild(item);
    });
  }

  async function deleteConversation(id) {
    try {
      const r = await fetch(`/api/conversations/${id}`, { method: 'DELETE' });
      if (requireAuth(r)) return;
    } catch {}
    conversations = conversations.filter(c => c.id !== id);
    if (currentId === id) {
      currentId = null;
      messagesEl.innerHTML = '';
      messagesEl.appendChild(buildWelcome());
      welcomeVisible = true;
    }
    renderSidebar();
  }

  function esc(s) {
    return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // ── Conversation management ───────────────────────────────────────
  function newConversation() {
    // A new conversation row is created server-side on the first message.
    currentId = null;
    welcomeVisible = true;
    messagesEl.innerHTML = '';
    messagesEl.appendChild(buildWelcome());
    renderSidebar();
    inputEl.focus();
    closeSidebar();
  }

  async function loadConversation(id) {
    try {
      const r = await fetch(`/api/conversations/${id}`);
      if (requireAuth(r)) return;
      if (!r.ok) return;
      const conv = await r.json();
      currentId = id;
      welcomeVisible = false;
      messagesEl.innerHTML = '';
      (conv.messages || []).forEach(m => renderMessage(m.role, m.content));
      renderSidebar();
      closeSidebar();
    } catch {}
  }

  // After the first reply, upgrade the auto-title to a nicer AI-generated one.
  async function upgradeTitle(convId, userMessage, botReply) {
    try {
      const r = await fetch('/api/title', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: userMessage, reply: botReply })
      });
      const data = await r.json();
      const raw = (data.title || '').trim();
      if (!raw || raw.length > 50) return;
      // Persist the better title server-side, then reflect it in the sidebar.
      await fetch(`/api/conversations/${convId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: raw })
      });
      const conv = conversations.find(c => c.id === convId);
      if (conv) { conv.title = raw; animateTitle(convId, raw); }
    } catch {}
  }

  // Typewriter effect: writes the title letter by letter into the sidebar item
  function animateTitle(convId, title) {
    renderSidebar(); // rebuild list with final data, then overwrite the one span
    const item = document.querySelector(`.conv-item[data-id="${convId}"]`);
    if (!item) return;
    const span = item.querySelector('span');
    span.textContent = '';
    let i = 0;
    const tick = setInterval(() => {
      span.textContent += title[i++];
      if (i >= title.length) clearInterval(tick);
    }, 35);
  }

  function buildWelcome() {
    const div = document.createElement('div');
    div.className = 'welcome';
    div.id = 'welcome';
    div.innerHTML = `
      <div class="welcome-emblem">
        <svg viewBox="0 0 100 100" fill="none">
          <rect x="0.5" y="0.5" width="99" height="99" stroke="#9B2D3A" stroke-width="0.8" fill="none"/>
          <line x1="0" y1="0" x2="14" y2="0" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="0" y1="0" x2="0" y2="14" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="100" y1="0" x2="86" y2="0" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="100" y1="0" x2="100" y2="14" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="0" y1="100" x2="14" y2="100" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="0" y1="100" x2="0" y2="86" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="100" y1="100" x2="86" y2="100" stroke="#C4556A" stroke-width="1.5"/>
          <line x1="100" y1="100" x2="100" y2="86" stroke="#C4556A" stroke-width="1.5"/>
          <text x="52" y="48" font-family="Cormorant Garamond, serif" font-size="28" font-weight="500"
                fill="#9B2D3A" text-anchor="middle" letter-spacing="5">ERA</text>
          <line x1="18" y1="57" x2="82" y2="57" stroke="#C4556A" stroke-width="0.8" opacity="0.6"/>
          <text x="54" y="72" font-family="Jost, sans-serif" font-size="13" font-weight="300"
                fill="#7a7060" text-anchor="middle" letter-spacing="8">AI</text>
        </svg>
      </div>
      <h1>Bine ați venit<br/>la asistentul dumneavoastră</h1>
      <p>Sunt aici să vă ajut cu eficiența în activitatea juridică — de la redactarea documentelor până la cercetare și organizare.</p>
      <div class="suggestions">
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Redactează un contract</button>
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Rezumă un document</button>
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Cercetare juridică</button>
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Redactează o scrisoare</button>
      </div>`;
    return div;
  }

  // ── Rendering helpers ─────────────────────────────────────────────
  const _avatarSvg = `<svg viewBox="0 0 32 32" width="18" height="18" fill="none">
    <circle cx="16" cy="16" r="4.5" fill="#9B2D3A" opacity="0.15"/>
    <circle cx="16" cy="16" r="2.5" fill="#9B2D3A"/>
    <circle cx="16" cy="7"  r="1.8" fill="#C4556A"/>
    <circle cx="25" cy="16" r="1.8" fill="#C4556A"/>
    <circle cx="16" cy="25" r="1.8" fill="#C4556A"/>
