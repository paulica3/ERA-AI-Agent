@page
@model IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ERA AI — Efrim Roșca &amp; Asociații</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png"/>
  <link rel="icon" href="/favicon.ico" sizes="any"/>
  <link rel="apple-touch-icon" href="/favicon-32.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/site.css"/>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>
<body>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<!-- ── SIDEBAR ─────────────────────────────────────────────────────── -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <svg viewBox="0 0 32 32" fill="none" width="26" height="26" style="flex-shrink:0">
      <rect x="0.5" y="0.5" width="31" height="31" stroke="#8b6914" stroke-width="0.8" fill="none"/>
      <line x1="0" y1="0" x2="6" y2="0" stroke="#c9a84c" stroke-width="1.2"/>
      <line x1="0" y1="0" x2="0" y2="6" stroke="#c9a84c" stroke-width="1.2"/>
      <line x1="32" y1="0" x2="26" y2="0" stroke="#c9a84c" stroke-width="1.2"/>
      <line x1="32" y1="0" x2="32" y2="6" stroke="#c9a84c" stroke-width="1.2"/>
      <line x1="0" y1="32" x2="6" y2="32" stroke="#c9a84c" stroke-width="1.2"/>
      <line x1="0" y1="32" x2="0" y2="26" stroke="#c9a84c" stroke-width="1.2"/>
      <line x1="32" y1="32" x2="26" y2="32" stroke="#c9a84c" stroke-width="1.2"/>
      <line x1="32" y1="32" x2="32" y2="26" stroke="#c9a84c" stroke-width="1.2"/>
      <text x="16" y="15" font-family="Cormorant Garamond, serif" font-size="8.5" font-weight="500"
            fill="#8b6914" text-anchor="middle" letter-spacing="1.5">ERA</text>
      <line x1="7" y1="18" x2="25" y2="18" stroke="#c9a84c" stroke-width="0.5" opacity="0.6"/>
      <text x="17" y="25" font-family="Jost, sans-serif" font-size="5" font-weight="300"
            fill="#7a7060" text-anchor="middle" letter-spacing="3">AI</text>
    </svg>
    <button class="sidebar-toggle" id="sidebarToggle" onclick="toggleSidebar()" title="Minimizează">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
  </div>

  <div class="sidebar-collapsible">
    <div class="sidebar-label">Conversații</div>
    <div class="sidebar-list" id="sidebarList"></div>
    <div class="sidebar-footer">
      <button class="new-chat-btn" onclick="newConversation()">
        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Conversație nouă
      </button>
    </div>
  </div>
</aside>

<!-- ── MAIN ───────────────────────────────────────────────────────── -->
<div class="main">
  <header>
    <button class="menu-btn" id="menuBtn" onclick="openSidebar()" title="Conversații">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <div class="logo-mark">
      <svg viewBox="0 0 48 48" fill="none">
        <rect x="0.5" y="0.5" width="47" height="47" stroke="#8b6914" stroke-width="1" fill="none"/>
        <line x1="0" y1="0" x2="7" y2="0"   stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="0" y1="0" x2="0" y2="7"   stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="48" y1="0"  x2="41" y2="0"  stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="48" y1="0"  x2="48" y2="7"  stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="0"  y1="48" x2="7"  y2="48" stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="0"  y1="48" x2="0"  y2="41" stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="48" y1="48" x2="41" y2="48" stroke="#c9a84c" stroke-width="1.2"/>
        <line x1="48" y1="48" x2="48" y2="41" stroke="#c9a84c" stroke-width="1.2"/>
        <text x="25" y="22" font-family="Cormorant Garamond, serif" font-size="13" font-weight="500"
              fill="#8b6914" text-anchor="middle" letter-spacing="2">ERA</text>
        <line x1="10" y1="27" x2="38" y2="27" stroke="#c9a84c" stroke-width="0.6" opacity="0.6"/>
        <text x="26" y="38" font-family="Jost, sans-serif" font-size="8" font-weight="300"
              fill="#7a7060" text-anchor="middle" letter-spacing="4">AI</text>
      </svg>
    </div>
    <div class="header-text">
      <div class="firm-name">Efrim Roșca <span>&amp;</span> Asociații</div>
      <div class="firm-sub">Asistent Juridic AI</div>
    </div>
    <div class="header-right">
      <div class="status-dot"></div>
      <span class="status-label">Activ</span>
    </div>
  </header>

  <!-- ── TAB BAR ──────────────────────────────────────────────────── -->
  <div class="tab-bar">
    <button class="tab-btn active" id="tabChat" onclick="switchTab('chat')">Conversație</button>
    <button class="tab-btn" id="tabAnalyze" onclick="switchTab('analyze')">Analiză Document</button>
  </div>

  <!-- ── ANALYZE PANEL ─────────────────────────────────────────────── -->
  <div class="analyze-panel" id="analyzePanel" style="display:none">
    <div class="upload-zone" id="uploadZone"
         ondragover="event.preventDefault(); this.classList.add('drag-over')"
         ondragleave="this.classList.remove('drag-over')"
         ondrop="handleDrop(event)"
         onclick="document.getElementById('fileInput').click()">
      <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
      <p>Trageți un document PDF sau DOCX aici</p>
      <span class="upload-hint">PDF · DOCX</span>
      <input type="file" id="fileInput" accept=".pdf,.docx" style="display:none" onchange="handleFileSelect(this)"/>
    </div>
    <div class="file-selected" id="fileSelected" style="display:none">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      <span id="fileSelectedName"></span>
    </div>
    <button class="analyze-btn" id="analyzeBtn" onclick="analyzeDocument()" disabled>Analizează</button>

    <div class="analyze-loading" id="analyzeLoading" style="display:none">
      <div class="analyze-loading-dots">
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
      </div>
      <span class="analyze-loading-text">Se analizează documentul...</span>
    </div>

    <div class="analysis-results" id="analysisResults" style="display:none"></div>
  </div>

  <div class="messages" id="messages">
    <div class="welcome" id="welcome">
      <div class="welcome-emblem">
        <svg viewBox="0 0 100 100" fill="none">
          <rect x="0.5" y="0.5" width="99" height="99" stroke="#8b6914" stroke-width="0.8" fill="none"/>
          <line x1="0" y1="0" x2="14" y2="0"    stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="0" y1="0" x2="0"  y2="14"   stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="100" y1="0"   x2="86"  y2="0"   stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="100" y1="0"   x2="100" y2="14"  stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="0"   y1="100" x2="14"  y2="100" stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="0"   y1="100" x2="0"   y2="86"  stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="100" y1="100" x2="86"  y2="100" stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="100" y1="100" x2="100" y2="86"  stroke="#c9a84c" stroke-width="1.5"/>
          <text x="52" y="48" font-family="Cormorant Garamond, serif" font-size="28" font-weight="500"
                fill="#8b6914" text-anchor="middle" letter-spacing="5">ERA</text>
          <line x1="18" y1="57" x2="82" y2="57" stroke="#c9a84c" stroke-width="0.8" opacity="0.6"/>
          <text x="54" y="72" font-family="Jost, sans-serif" font-size="13" font-weight="300"
                fill="#7a7060" text-anchor="middle" letter-spacing="8">AI</text>
        </svg>
      </div>
      <h1>Bine ați venit<br/>la asistentul dumneavoastră</h1>
      <p>Sunt aici să vă ajut cu eficiența în activitatea juridică — de la redactarea documentelor până la cercetare și organizare.</p>
      <div class="suggestions">
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Redactează un contract</button>
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Rezumă un document</button>
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Cercetare juridică</button>
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Redactează o scrisoare</button>
      </div>
    </div>
  </div>

  <div class="input-area" id="inputArea">
    <div class="input-wrap">
      <textarea
        id="userInput"
        placeholder="Introduceți întrebarea sau solicitarea dumneavoastră..."
        rows="1"
        oninput="autoResize(this); updateCharCount(this);"
        onkeydown="handleKey(event)"
      ></textarea>
      <button class="send-btn" onclick="sendMessage()" title="Trimite">
        <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>
    <div class="input-footer">
      <span class="input-hint">Enter — trimite &nbsp;·&nbsp; Shift+Enter — linie nouă</span>
      <span class="char-count" id="charCount">0</span>
    </div>
  </div>

  <footer>
    <div>Efrim Roșca <span>&amp;</span> Asociații &nbsp;·&nbsp; ERA AI</div>
    <div>Chișinău, Moldova<span class="footer-sep"></span>© 2025</div>
  </footer>
</div>

<script>
  // ── DOM refs ──────────────────────────────────────────────────────
  const messagesEl = document.getElementById('messages');
  const inputEl    = document.getElementById('userInput');
  let welcomeVisible = true;

  // ── Conversation store (persisted in localStorage) ────────────────
  // Shape: { id: string, title: string, messages: {role, content}[] }[]
  let conversations = JSON.parse(localStorage.getItem('era_convs') || '[]');
  let currentId = null;

  function save() {
    localStorage.setItem('era_convs', JSON.stringify(conversations));
  }

  function getCurrent() {
    return conversations.find(c => c.id === currentId) || null;
  }

  // ── Sidebar ───────────────────────────────────────────────────────
  function renderSidebar() {
    const list = document.getElementById('sidebarList');
    list.innerHTML = '';

    if (conversations.length === 0) {
      list.innerHTML = '<div class="sidebar-empty">Nicio conversație încă</div>';
      return;
    }

    // Most recent first
    conversations.slice().reverse().forEach(conv => {
      const item = document.createElement('div');
      item.className = 'conv-item' + (conv.id === currentId ? ' active' : '');
      item.innerHTML = `
        <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke-linejoin="round"/></svg>
        <span>${esc(conv.title)}</span>`;
      item.onclick = () => loadConversation(conv.id);
      list.appendChild(item);
    });
  }

  function esc(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // ── Conversation management ───────────────────────────────────────
  function newConversation() {
    currentId = null;
    welcomeVisible = true;
    messagesEl.innerHTML = '';
    messagesEl.appendChild(buildWelcome());
    renderSidebar();
    inputEl.focus();
  }

  function loadConversation(id) {
    const conv = conversations.find(c => c.id === id);
    if (!conv) return;
    currentId = id;
    welcomeVisible = false;
    messagesEl.innerHTML = '';
    conv.messages.forEach(m => renderMessage(m.role, m.content));
    renderSidebar();
  }

  function startConversation(firstMessage) {
    const id = crypto.randomUUID ? crypto.randomUUID() : Date.now().toString();
    const title = firstMessage.length > 42 ? firstMessage.slice(0, 42) + '…' : firstMessage;
    const conv = { id, title, messages: [] };
    conversations.push(conv);
    currentId = id;
    save();
    renderSidebar();
    return conv;
  }

  function buildWelcome() {
    const div = document.createElement('div');
    div.className = 'welcome';
    div.id = 'welcome';
    div.innerHTML = `
      <div class="welcome-emblem">
        <svg viewBox="0 0 100 100" fill="none">
          <rect x="0.5" y="0.5" width="99" height="99" stroke="#8b6914" stroke-width="0.8" fill="none"/>
          <line x1="0" y1="0" x2="14" y2="0" stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="0" y1="0" x2="0" y2="14" stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="100" y1="0" x2="86" y2="0" stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="100" y1="0" x2="100" y2="14" stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="0" y1="100" x2="14" y2="100" stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="0" y1="100" x2="0" y2="86" stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="100" y1="100" x2="86" y2="100" stroke="#c9a84c" stroke-width="1.5"/>
          <line x1="100" y1="100" x2="100" y2="86" stroke="#c9a84c" stroke-width="1.5"/>
          <text x="52" y="48" font-family="Cormorant Garamond, serif" font-size="28" font-weight="500"
                fill="#8b6914" text-anchor="middle" letter-spacing="5">ERA</text>
          <line x1="18" y1="57" x2="82" y2="57" stroke="#c9a84c" stroke-width="0.8" opacity="0.6"/>
          <text x="54" y="72" font-family="Jost, sans-serif" font-size="13" font-weight="300"
                fill="#7a7060" text-anchor="middle" letter-spacing="8">AI</text>
        </svg>
      </div>
      <h1>Bine ați venit<br/>la asistentul dumneavoastră</h1>
      <p>Sunt aici să vă ajut cu eficiența în activitatea juridică — de la redactarea documentelor până la cercetare și organizare.</p>
      <div class="suggestions">
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Redactează un contract</button>
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Rezumă un document</button>
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Cercetare juridică</button>
        <button class="suggestion-btn" onclick="sendSuggestion(this)">Redactează o scrisoare</button>
      </div>`;
    return div;
  }

  // ── Rendering helpers ─────────────────────────────────────────────
  function renderMessage(role, text) {
    const isUser = role === 'user';
    const msg = document.createElement('div');
    msg.className = `msg ${role}`;

    const avatarSvg = `<svg viewBox="0 0 32 32" width="18" height="18" fill="none">
      <circle cx="16" cy="16" r="4.5" fill="#8b6914" opacity="0.15"/>
      <circle cx="16" cy="16" r="2.5" fill="#8b6914"/>
      <circle cx="16" cy="7"  r="1.8" fill="#c9a84c"/>
      <circle cx="25" cy="16" r="1.8" fill="#c9a84c"/>
      <circle cx="16" cy="25" r="1.8" fill="#c9a84c"/>
      <circle cx="7"  cy="16" r="1.8" fill="#c9a84c"/>
      <line x1="16" y1="13.5" x2="16" y2="8.8"   stroke="#8b6914" stroke-width="0.6" opacity="0.3"/>
      <line x1="18.5" y1="16" x2="23.2" y2="16"  stroke="#8b6914" stroke-width="0.6" opacity="0.3"/>
      <line x1="16" y1="18.5" x2="16" y2="23.2"  stroke="#8b6914" stroke-width="0.6" opacity="0.3"/>
      <line x1="13.5" y1="16" x2="8.8" y2="16"   stroke="#8b6914" stroke-width="0.6" opacity="0.3"/>
    </svg>`;

    const avatar = document.createElement('div');
    avatar.className = 'msg-avatar';
    avatar.innerHTML = isUser ? '<span>DV</span>' : avatarSvg;

    const body = document.createElement('div');
    body.className = 'msg-body';

    const sender = document.createElement('div');
    sender.className = 'msg-sender';
    sender.textContent = isUser ? 'Dumneavoastră' : 'ERA AI · Efrim Roșca & Asociații';

    const bubble = document.createElement('div');
    bubble.className = 'msg-bubble';

    if (isUser) {
      bubble.textContent = text;
    } else {
      bubble.innerHTML = marked.parse(text);
    }

    body.appendChild(sender);
    body.appendChild(bubble);
    msg.appendChild(avatar);
    msg.appendChild(body);
    messagesEl.appendChild(msg);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function showTyping() {
    const wrap = document.createElement('div');
    wrap.className = 'msg assistant';
    wrap.id = 'typingWrap';
    wrap.innerHTML = `
      <div class="msg-avatar">
        <svg viewBox="0 0 32 32" width="18" height="18" fill="none">
          <circle cx="16" cy="16" r="4.5" fill="#8b6914" opacity="0.15"/>
          <circle cx="16" cy="16" r="2.5" fill="#8b6914"/>
          <circle cx="16" cy="7"  r="1.8" fill="#c9a84c"/>
          <circle cx="25" cy="16" r="1.8" fill="#c9a84c"/>
          <circle cx="16" cy="25" r="1.8" fill="#c9a84c"/>
          <circle cx="7"  cy="16" r="1.8" fill="#c9a84c"/>
        </svg>
      </div>
      <div class="msg-body">
        <div class="msg-sender">ERA AI · Efrim Roșca & Asociații</div>
        <div class="typing-indicator">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>
      </div>`;
    messagesEl.appendChild(wrap);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function removeTyping() {
    const el = document.getElementById('typingWrap');
    if (el) el.remove();
  }

  // ── Input helpers ─────────────────────────────────────────────────
  function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 120) + 'px';
  }

  function updateCharCount(el) {
    document.getElementById('charCount').textContent = el.value.length;
  }

  function handleKey(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  }

  function sendSuggestion(btn) {
    inputEl.value = btn.textContent;
    sendMessage();
  }

  function hideWelcome() {
    if (!welcomeVisible) return;
    const el = document.getElementById('welcome');
    if (el) {
      el.style.transition = 'opacity 0.25s ease';
      el.style.opacity = '0';
      setTimeout(() => el.remove(), 250);
    }
    welcomeVisible = false;
  }

  // ── Send ──────────────────────────────────────────────────────────
  async function sendMessage() {
    const text = inputEl.value.trim();
    if (!text) return;

    hideWelcome();

    if (!currentId) startConversation(text);

    const conv = getCurrent();
    conv.messages.push({ role: 'user', content: text });
    save();

    renderMessage('user', text);
    inputEl.value = '';
    inputEl.style.height = 'auto';
    document.getElementById('charCount').textContent = '0';

    showTyping();

    try {
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: conv.messages })
      });
      const data = await response.json();
      removeTyping();
      conv.messages.push({ role: 'assistant', content: data.reply });
      save();
      renderMessage('assistant', data.reply);
    } catch {
      removeTyping();
      renderMessage('assistant', 'Ne cerem scuze, a apărut o eroare. Vă rugăm să încercați din nou.');
    }
  }

  // ── Sidebar toggle ────────────────────────────────────────────────
  function isMobile() { return window.innerWidth <= 768; }

  function toggleSidebar() {
    if (isMobile()) {
      closeSidebar();
    } else {
      document.getElementById('sidebar').classList.toggle('collapsed');
    }
  }

  function openSidebar() {
    document.getElementById('sidebar').classList.add('open');
    document.getElementById('sidebarOverlay').classList.add('visible');
  }

  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('visible');
  }

  // ── Tab switching ─────────────────────────────────────────────────
  function switchTab(tab) {
    const isChat = tab === 'chat';
    document.getElementById('messages').style.display      = isChat ? '' : 'none';
    document.getElementById('inputArea').style.display     = isChat ? '' : 'none';
    document.getElementById('analyzePanel').style.display  = isChat ? 'none' : '';
    document.getElementById('tabChat').classList.toggle('active', isChat);
    document.getElementById('tabAnalyze').classList.toggle('active', !isChat);
  }

  // ── Document analysis ─────────────────────────────────────────────
  function handleFileSelect(input) {
    const file = input.files[0];
    if (!file) return;
    document.getElementById('fileSelectedName').textContent = file.name;
    document.getElementById('fileSelected').style.display = 'flex';
    document.getElementById('analyzeBtn').disabled = false;
  }

  function handleDrop(event) {
    event.preventDefault();
    document.getElementById('uploadZone').classList.remove('drag-over');
    const file = event.dataTransfer.files[0];
    if (!file) return;
    const dt = new DataTransfer();
    dt.items.add(file);
    document.getElementById('fileInput').files = dt.files;
    handleFileSelect(document.getElementById('fileInput'));
  }

  async function analyzeDocument() {
    const fileInput = document.getElementById('fileInput');
    const file = fileInput.files[0];
    if (!file) return;

    const btn = document.getElementById('analyzeBtn');
    btn.disabled = true;
    btn.textContent = 'Analizează';

    const resultsEl = document.getElementById('analysisResults');
    resultsEl.style.display = 'none';
    resultsEl.innerHTML = '';
    document.getElementById('analyzeLoading').style.display = 'flex';

    try {
      const formData = new FormData();
      formData.append('file', file);

      const response = await fetch('http://localhost:8000/analyze', {
        method: 'POST',
        body: formData
      });

      if (!response.ok) {
        const err = await response.json();
        throw new Error(err.detail || 'Eroare server');
      }

      const data = await response.json();

      resultsEl.innerHTML = `
        <div class="analysis-card">
          <div class="analysis-card-header">Rezumat</div>
          <div class="analysis-card-body">${marked.parse(data.summary)}</div>
        </div>
        <div class="analysis-card">
          <div class="analysis-card-header">Clauze &amp; Riscuri</div>
          <div class="analysis-card-body">${marked.parse(data.clauses)}</div>
        </div>`;
      resultsEl.style.display = 'flex';

    } catch (e) {
      resultsEl.innerHTML = `<div class="analysis-card"><div class="analysis-card-body" style="color:var(--red-accent)">Eroare: ${e.message}. Verificați că serverul Python este pornit pe portul 8000.</div></div>`;
      resultsEl.style.display = 'flex';
    } finally {
      document.getElementById('analyzeLoading').style.display = 'none';
      btn.disabled = false;
    }
  }

  // ── Init ──────────────────────────────────────────────────────────
  renderSidebar();
</script>

</body>
</html>
