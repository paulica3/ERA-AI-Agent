@page
@model IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ERA AI — Efrim Roșca &amp; Asociații</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png"/>
  <link rel="icon" href="/favicon.ico" sizes="any"/>
  <link rel="apple-touch-icon" href="/favicon-32.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/site.css"/>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>
<body>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<!-- ── SIDEBAR ─────────────────────────────────────────────────────── -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <svg viewBox="0 0 32 32" fill="none" width="26" height="26" style="flex-shrink:0">
      <rect x="0.5" y="0.5" width="31" height="31" stroke="#9B2D3A" stroke-width="0.8" fill="none"/>
      <line x1="0" y1="0" x2="6" y2="0" stroke="#C4556A" stroke-width="1.2"/>
      <line x1="0" y1="0" x2="0" y2="6" stroke="#C4556A" stroke-width="1.2"/>
      <line x1="32" y1="0" x2="26" y2="0" stroke="#C4556A" stroke-width="1.2"/>
      <line x1="32" y1="0" x2="32" y2="6" stroke="#C4556A" stroke-width="1.2"/>
      <line x1="0" y1="32" x2="6" y2="32" stroke="#C4556A" stroke-width="1.2"/>
      <line x1="0" y1="32" x2="0" y2="26" stroke="#C4556A" stroke-width="1.2"/>
      <line x1="32" y1="32" x2="26" y2="32" stroke="#C4556A" stroke-width="1.2"/>
      <line x1="32" y1="32" x2="32" y2="26" stroke="#C4556A" stroke-width="1.2"/>
      <text x="16" y="15" font-family="Cormorant Garamond, serif" font-size="8.5" font-weight="500"
            fill="#9B2D3A" text-anchor="middle" letter-spacing="1.5">ERA</text>
      <line x1="7" y1="18" x2="25" y2="18" stroke="#C4556A" stroke-width="0.5" opacity="0.6"/>
      <text x="17" y="25" font-family="Jost, sans-serif" font-size="5" font-weight="300"
            fill="#7a7060" text-anchor="middle" letter-spacing="3">AI</text>
    </svg>
    <button class="sidebar-toggle" id="sidebarToggle" onclick="toggleSidebar()" title="Minimizează">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
  </div>

  <div class="sidebar-collapsible">
    <div class="sidebar-label">Conversații</div>
    <div class="sidebar-list" id="sidebarList"></div>
    <div class="sidebar-footer">
      <button class="new-chat-btn" onclick="newConversation()">
        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Conversație nouă
      </button>
    </div>
  </div>
</aside>

<!-- ── MAIN ───────────────────────────────────────────────────────── -->
<div class="main">
  <header>
    <button class="menu-btn" id="menuBtn" onclick="openSidebar()" title="Conversații">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <div class="logo-mark">
      <svg viewBox="0 0 48 48" fill="none">
        <rect x="0.5" y="0.5" width="47" height="47" stroke="#9B2D3A" stroke-width="1" fill="none"/>
        <line x1="0" y1="0" x2="7" y2="0"   stroke="#C4556A" stroke-width="1.2"/>
        <line x1="0" y1="0" x2="0" y2="7"   stroke="#C4556A" stroke-width="1.2"/>
        <line x1="48" y1="0"  x2="41" y2="0"  stroke="#C4556A" stroke-width="1.2"/>
        <line x1="48" y1="0"  x2="48" y2="7"  stroke="#C4556A" stroke-width="1.2"/>
        <line x1="0"  y1="48" x2="7"  y2="48" stroke="#C4556A" stroke-width="1.2"/>
        <line x1="0"  y1="48" x2="0"  y2="41" stroke="#C4556A" stroke-width="1.2"/>
        <line x1="48" y1="48" x2="41" y2="48" stroke="#C4556A" stroke-width="1.2"/>
        <line x1="48" y1="48" x2="48" y2="41" stroke="#C4556A" stroke-width="1.2"/>
        <text x="25" y="22" font-family="Cormorant Garamond, serif" font-size="13" font-weight="500"
              fill="#9B2D3A" text-anchor="middle" letter-spacing="2">ERA</text>
        <line x1="10" y1="27" x2="38" y2="27" stroke="#C4556A" stroke-width="0.6" opacity="0.6"/>
        <text x="26" y="38" font-family="Jost, sans-serif" font-size="8" font-weight="300"
              fill="#7a7060" text-anchor="middle" letter-spacing="4">AI</text>
      </svg>
    </div>
    <div class="header-text">
      <div class="firm-name">Efrim Roșca <span>&amp;</span> Asociații</div>
      <div class="firm-sub">Asistent Juridic AI</div>
    </div>
    <div class="header-right">
      <a class="dashboard-link" href="/Account" title="Contul și preferințele dumneavoastră" style="text-decoration:none;color:var(--ink-muted);border:1px solid var(--border);padding:6px 14px;margin-right:10px;font-family:'Jost',sans-serif;font-size:9px;font-weight:400;letter-spacing:2px;text-transform:uppercase;transition:color .15s,border-color .15s;" onmouseover="this.style.color='var(--gold)';this.style.borderColor='var(--gold)'" onmouseout="this.style.color='var(--ink-muted)';this.style.borderColor='var(--border)'">Contul meu</a>
      <a class="dashboard-link" href="/Dashboard" title="Editează proiectele firmei" style="text-decoration:none;color:var(--ink-muted);border:1px solid var(--border);padding:6px 14px;margin-right:14px;font-family:'Jost',sans-serif;font-size:9px;font-weight:400;letter-spacing:2px;text-transform:uppercase;transition:color .15s,border-color .15s;" onmouseover="this.style.color='var(--gold)';this.style.borderColor='var(--gold)'" onmouseout="this.style.color='var(--ink-muted)';this.style.borderColor='var(--border)'">Portofoliu proiecte</a>
      <div class="status-dot"></div>
      <span class="status-label">Activ</span>
    </div>
  </header>

  <!-- ── TAB BAR ──────────────────────────────────────────────────── -->
  <div class="tab-bar">
    <button class="tab-btn active" id="tabChat" onclick="switchTab('chat')">Conversație</button>
    <button class="tab-btn" id="tabAnalyze" onclick="switchTab('analyze')">Analiză Document</button>
    <button class="tab-btn" id="tabDraft" onclick="switchTab('draft')">Redactare Contract</button>
    <button class="tab-btn" id="tabInvoice" onclick="switchTab('invoice')">Factură</button>
    <button class="tab-btn" id="tabOffer" onclick="switchTab('offer')">Ofertă</button>
    <button class="tab-btn" id="tabGenDesc" onclick="switchTab('gendesc')">Prezentare Generală</button>
  </div>

  <!-- ── ANALYZE PANEL ─────────────────────────────────────────────── -->
  <div class="analyze-panel" id="analyzePanel" style="display:none">
    <div class="upload-zone" id="uploadZone"
         ondragover="event.preventDefault(); this.classList.add('drag-over')"
         ondragleave="this.classList.remove('drag-over')"
         ondrop="handleDrop(event)"
         onclick="document.getElementById('fileInput').click()">
      <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
      <p>Trageți un document PDF sau DOCX aici</p>
      <span class="upload-hint">PDF · DOCX</span>
      <input type="file" id="fileInput" accept=".pdf,.docx" style="display:none" onchange="handleFileSelect(this)"/>
    </div>
    <div class="file-selected" id="fileSelected" style="display:none">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      <span id="fileSelectedName"></span>
    </div>
    <button class="analyze-btn" id="analyzeBtn" onclick="analyzeDocument()" disabled>Analizează</button>

    <div class="wine-loading" id="analyzeLoading" style="display:none">
      <svg class="wine-anim-svg" viewBox="0 0 220 218" xmlns="http://www.w3.org/2000/svg">
        <g class="wb-g">
          <path class="wb-glass" d="M94,14 L116,14 L116,24 L118,27 L117,33 L117,67 Q137,82 137,103 L137,163 Q137,184 105,184 Q73,184 73,163 L73,103 Q73,82 93,67 L93,33 L92,27 L94,24 Z"/>
          <rect class="wb-cap" x="94" y="14" width="22" height="11" rx="2"/>
          <path class="wb-wine" d="M79,130 L79,161 Q79,178 105,178 Q131,178 131,161 L131,130 Z"/>
          <rect class="wb-label" x="82" y="118" width="46" height="48" rx="1.5"/>
          <text class="wb-era" x="105" y="137" text-anchor="middle">ERA</text>
          <text class="wb-ai" x="105" y="154" text-anchor="middle">AI</text>
          <ellipse class="wb-shine" cx="79" cy="140" rx="3.5" ry="18"/>
        </g>
        <path class="wb-stream" d="M179,143 Q188,162 182,180 Q176,198 184,213"/>
        <ellipse class="wb-drop wb-drop-1" cx="183" cy="215" rx="5" ry="6.5"/>
        <ellipse class="wb-drop wb-drop-2" cx="177" cy="204" rx="3.5" ry="4.5"/>
        <ellipse class="wb-drop wb-drop-3" cx="189" cy="208" rx="2.5" ry="3"/>
      </svg>
      <span class="analyze-loading-text">Se pregătește documentul...</span>
    </div>

    <div class="analysis-results" id="analysisResults" style="display:none"></div>
  </div>

  <!-- ── DRAFT PANEL ───────────────────────────────────────────────── -->
  <div class="draft-panel" id="draftPanel" style="display:none">

    <div class="draft-form" id="draftForm">

      <div class="draft-section">
        <div class="draft-section-title">Date Client</div>
        <div class="draft-row">
          <div class="draft-field">
            <label class="draft-label" for="clientName">Denumire companie / persoană</label>
            <input class="draft-input" type="text" id="clientName" placeholder="Ex: Draexlmaier Automotive"/>
          </div>
          <div class="draft-field">
            <label class="draft-label" for="clientType">Formă juridică</label>
            <select class="draft-select" id="clientType">
              <option value="SRL">SRL</option>
              <option value="SA">SA</option>
              <option value="SCS">SCS</option>
              <option value="ÎI">Întreprindere Individuală (ÎI)</option>
              <option value="persoană fizică">Persoană Fizică</option>
            </select>
          </div>
        </div>
        <div class="draft-row">
          <div class="draft-field">
            <label class="draft-label" for="clientIdno">IDNO <span class="optional">— opțional</span></label>
            <input class="draft-input" type="text" id="clientIdno" placeholder="Ex: 1007602000178"/>
          </div>
          <div class="draft-field">
            <label class="draft-label" for="contractNumber">Nr. Contract <span class="optional">— opțional</span></label>
            <input class="draft-input" type="text" id="contractNumber" placeholder="Ex: 001/25 (generat automat dacă gol)"/>
          </div>
        </div>
        <div class="draft-field">
          <label class="draft-label" for="clientAddress">Adresă juridică <span class="optional">— opțional</span></label>
          <input class="draft-input" type="text" id="clientAddress" placeholder="Ex: mun. Chișinău, str. București, 72"/>
        </div>
        <div class="draft-row">
          <div class="draft-field">
            <label class="draft-label" for="clientRep">Reprezentant legal <span class="optional">— opțional</span></label>
            <input class="draft-input" type="text" id="clientRep" placeholder="Prenume NUME"/>
          </div>
          <div class="draft-field">
            <label class="draft-label" for="clientRepRole">Calitate reprezentant <span class="optional">— opțional</span></label>
            <input class="draft-input" type="text" id="clientRepRole" placeholder="Ex: Administrator"/>
          </div>
        </div>
      </div>

      <div class="draft-section">
        <div class="draft-section-title">Obiectul Contractului</div>
        <div class="draft-field">
          <label class="draft-label" for="contractScope">Descrierea cazului / misiunii</label>
          <textarea class="draft-textarea" id="contractScope" placeholder="Descrieți cazul juridic — litigiul, tipul de asistență solicitată, instanțele implicate, contextul..."></textarea>
        </div>
        <div class="draft-field">
          <label class="draft-label" for="contractServices">Servicii specifice ERA <span class="optional">— opțional (generate automat dacă gol)</span></label>
          <textarea class="draft-textarea" id="contractServices" placeholder="Ex:&#10;Analiza dosarului și formularea recomandărilor;&#10;Redactarea documentelor procesuale;&#10;Reprezentare în instanță;"></textarea>
        </div>
      </div>

      <div class="draft-section">
        <div class="draft-section-title">Onorarii &amp; Durată</div>
        <div class="draft-field">
          <label class="draft-label" for="contractFees">Onorarii <span class="optional">— opțional (câte o linie per sumă)</span></label>
          <textarea class="draft-textarea" id="contractFees" placeholder="Ex:&#10;pentru analiza dosarului – 1.000 EUR;&#10;pentru reprezentare în instanță – 2.000 EUR per grad de jurisdicție;"></textarea>
        </div>
        <div class="draft-field">
          <label class="draft-label" for="contractDuration">Durata contractului <span class="optional">— opțional</span></label>
          <input class="draft-input" type="text" id="contractDuration" placeholder="Ex: pe durata examinării cazului în instanțele naționale"/>
        </div>
      </div>

    </div>

    <div class="draft-actions">
      <button class="draft-btn" id="draftBtn" onclick="draftContract()">Generează Contract</button>
      <div class="wine-loading" id="draftLoading" style="display:none">
        <svg class="wine-anim-svg" viewBox="0 0 220 218" xmlns="http://www.w3.org/2000/svg">
          <g class="wb-g">
            <path class="wb-glass" d="M94,14 L116,14 L116,24 L118,27 L117,33 L117,67 Q137,82 137,103 L137,163 Q137,184 105,184 Q73,184 73,163 L73,103 Q73,82 93,67 L93,33 L92,27 L94,24 Z"/>
            <rect class="wb-cap" x="94" y="14" width="22" height="11" rx="2"/>
            <path class="wb-wine" d="M79,130 L79,161 Q79,178 105,178 Q131,178 131,161 L131,130 Z"/>
            <rect class="wb-label" x="82" y="118" width="46" height="48" rx="1.5"/>
            <text class="wb-era" x="105" y="137" text-anchor="middle">ERA</text>
            <text class="wb-ai" x="105" y="154" text-anchor="middle">AI</text>
            <ellipse class="wb-shine" cx="79" cy="140" rx="3.5" ry="18"/>
          </g>
          <path class="wb-stream" d="M179,143 Q188,162 182,180 Q176,198 184,213"/>
          <ellipse class="wb-drop wb-drop-1" cx="183" cy="215" rx="5" ry="6.5"/>
          <ellipse class="wb-drop wb-drop-2" cx="177" cy="204" rx="3.5" ry="4.5"/>
          <ellipse class="wb-drop wb-drop-3" cx="189" cy="208" rx="2.5" ry="3"/>
        </svg>
        <span class="draft-loading-text">Se redactează contractul...</span>
      </div>
      <div class="draft-success-card" id="draftSuccess" style="display:none">
        <span class="draft-success-text">Contractul a fost generat cu succes.</span>
        <button class="draft-download-btn" id="draftDownloadBtn">Descarcă DOCX</button>
        <button class="draft-btn-ghost" onclick="resetDraft()">Contract Nou</button>
      </div>
      <div class="draft-error" id="draftError" style="display:none"></div>
    </div>

  </div>

  <!-- ── INVOICE PANEL ─────────────────────────────────────────────── -->
  <div class="draft-panel" id="invoicePanel" style="display:none">

    <div class="draft-form" id="invoiceForm">

      <div class="draft-section">
        <div class="draft-section-title">Client (Plătitor)</div>
        <div class="draft-row">
          <div class="draft-field">
            <label class="draft-label" for="invCompany">Denumire companie</label>
            <input class="draft-input" type="text" id="invCompany" placeholder="Ex: Eleving Group S.A."/>
          </div>
          <div class="draft-field">
            <label class="draft-label" for="invDate">Data facturii</label>
            <input class="draft-input" type="text" id="invDate" placeholder="Ex: 17 April 2025"/>
          </div>
        </div>
        <div class="draft-field">
          <label class="draft-label" for="invAddress">Adresă juridică <span class="optional">— opțional</span></label>
          <input class="draft-input" type="text" id="invAddress" placeholder="Ex: 8-10, Avenue de la Gare, L-1610 Luxembourg"/>
        </div>
        <div class="draft-row">
          <div class="draft-field">
            <label class="draft-label" for="invIban">IBAN client <span class="optional">— opțional</span></label>
            <input class="draft-input" type="text" id="invIban" placeholder="Ex: LV69LLBB0003204002280"/>
          </div>
          <div class="draft-field">
            <label class="draft-label" for="invRegNo">Reg. no <span class="optional">— opțional</span></label>
            <input class="draft-input" type="text" id="invRegNo" placeholder="Ex: B 174457"/>
          </div>
        </div>
        <div class="draft-field">
          <label class="draft-label" for="invVatNo">VAT no <span class="optional">— opțional</span></label>
          <input class="draft-input" type="text" id="invVatNo" placeholder="Ex: LU30145007"/>
        </div>
      </div>

      <div class="draft-section">
        <div class="draft-section-title">Referință Factură</div>
        <div class="draft-row">
          <div class="draft-field">
            <label class="draft-label" for="invNumber">Număr factură</label>
            <input class="draft-input" type="text" id="invNumber" placeholder="Ex: 01/17/04/2026"/>
          </div>
          <div class="draft-field">
            <label class="draft-label" for="invCurrency">Valută</label>
            <select class="draft-select" id="invCurrency">
              <option value="EUR">EUR</option>
              <option value="USD">USD</option>
              <option value="MDL">MDL</option>
            </select>
          </div>
        </div>
        <div class="draft-field">
          <label class="draft-label" for="invContractRef">Referință contract <span class="optional">— opțional</span></label>
          <input class="draft-input" type="text" id="invContractRef" placeholder="Ex: Client Contract 735/24 as of 10 September 2025"/>
        </div>
      </div>

      <div class="draft-section">
        <div class="draft-section-title">Servicii &amp; Onorarii</div>
        <div class="draft-field">
          <label class="draft-label" for="invServiceDesc">Descrierea serviciilor</label>
          <textarea class="draft-textarea" id="invServiceDesc" placeholder="Ex: Legal and transactional support related to the refinancing of the bonds..."></textarea>
        </div>
        <div class="draft-field">
          <label class="draft-label" for="invFee">Onorariu legal</label>
          <input class="draft-input" type="text" id="invFee" placeholder="Ex: 5500.00"/>
        </div>
        <div class="draft-field">
          <label class="draft-label" for="invExpenses">Cheltuieli out-of-pocket <span class="optional">— opțional, câte una per linie: Denumire: sumă</span></label>
          <textarea class="draft-textarea" id="invExpenses" placeholder="Ex:&#10;Notarial services: 117.78&#10;State duty: 5.69"></textarea>
        </div>
      </div>

      <div class="draft-section">
        <div class="draft-section-title">Semnatar</div>
        <div class="draft-row">
          <div class="draft-field">
            <label class="draft-label" for="invPartner">Nume partener</label>
            <input class="draft-input" type="text" id="invPartner" value="Oleg Efrim"/>
          </div>
          <div class="draft-field">
            <label class="draft-label" for="invPartnerTitle">Titlu</label>
            <input class="draft-input" type="text" id="invPartnerTitle" value="Partner"/>
          </div>
        </div>
        <div class="draft-field">
          <label class="draft-label" for="invPartnerEmail">Email</label>
          <input class="draft-input" type="text" id="invPartnerEmail" value="oleg.efrim@era.md"/>
        </div>
      </div>

    </div>

    <div class="draft-actions">
      <button class="draft-btn" id="invoiceBtn" onclick="draftInvoice()">Generează Factură</button>
      <div class="wine-loading" id="invoiceLoading" style="display:none">
        <svg class="wine-anim-svg" viewBox="0 0 220 218" xmlns="http://www.w3.org/2000/svg">
          <g class="wb-g">
            <path class="wb-glass" d="M94,14 L116,14 L116,24 L118,27 L117,33 L117,67 Q137,82 137,103 L137,163 Q137,184 105,184 Q73,184 73,163 L73,103 Q73,82 93,67 L93,33 L92,27 L94,24 Z"/>
            <rect class="wb-cap" x="94" y="14" width="22" height="11" rx="2"/>
            <path class="wb-wine" d="M79,130 L79,161 Q79,178 105,178 Q131,178 131,161 L131,130 Z"/>
            <rect class="wb-label" x="82" y="118" width="46" height="48" rx="1.5"/>
            <text class="wb-era" x="105" y="137" text-anchor="middle">ERA</text>
            <text class="wb-ai" x="105" y="154" text-anchor="middle">AI</text>
            <ellipse class="wb-shine" cx="79" cy="140" rx="3.5" ry="18"/>
          </g>
          <path class="wb-stream" d="M179,143 Q188,162 182,180 Q176,198 184,213"/>
          <ellipse class="wb-drop wb-drop-1" cx="183" cy="215" rx="5" ry="6.5"/>
          <ellipse class="wb-drop wb-drop-2" cx="177" cy="204" rx="3.5" ry="4.5"/>
          <ellipse class="wb-drop wb-drop-3" cx="189" cy="208" rx="2.5" ry="3"/>
        </svg>
        <span class="draft-loading-text">Se generează factura...</span>
      </div>
      <div class="draft-success-card" id="invoiceSuccess" style="display:none">
        <span class="draft-success-text">Factura a fost generată cu succes.</span>
        <button class="draft-download-btn" id="invoiceDownloadBtn">Descarcă DOCX</button>
        <button class="draft-btn-ghost" onclick="resetInvoice()">Factură Nouă</button>
      </div>
      <div class="draft-error" id="invoiceError" style="display:none"></div>
    </div>

  </div>

