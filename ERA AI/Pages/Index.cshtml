      lastGenDescBlob = await response.blob();
      lastGenDescFilename = `Prezentare_ERA.${fmt}`;
      triggerDownload(lastGenDescBlob, lastGenDescFilename);

      document.getElementById('gendescDownloadBtn').onclick = () => triggerDownload(lastGenDescBlob, lastGenDescFilename);
      document.getElementById('gendescSuccess').style.display = 'flex';
    } catch (e) {
      const errEl = document.getElementById('gendescError');
      errEl.textContent = `Eroare la generarea prezentării: ${e.message}`;
      errEl.style.display = 'block';
    } finally {
      document.getElementById('gendescLoading').style.display = 'none';
      btn.disabled = false;
    }
  }

  function resetGeneralDescription() {
    lastGenDescBlob = null;
    document.getElementById('gendescSuccess').style.display = 'none';
    document.getElementById('gendescError').style.display   = 'none';
    ['gdDate','gdSalutation','gdAddressee','gdIntro','gdRate']
      .forEach(id => { document.getElementById(id).value = ''; });
  }

  // ── Init ──────────────────────────────────────────────────────────
  loadConversations();
</script>

</body>
</html>
