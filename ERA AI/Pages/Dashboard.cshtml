@page
@model ERA_AI.Pages.DashboardModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>ERA AI — Portofoliu de proiecte</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="/css/site.css"/>
    <style>
        /* Dashboard — reuses the site's wine theme variables from site.css */
        body{ height:auto; min-height:100vh; overflow:auto; display:block; }

        .dash-topbar{ display:flex; align-items:center; gap:16px; padding:14px 28px;
            border-bottom:1px solid var(--border); background:var(--cream-dark); position:sticky; top:0; z-index:20; }
        .dash-topbar .logo-mark svg{ width:34px; height:34px; }
        .dash-title{ font-family:'Cormorant Garamond',serif; font-size:17px; font-weight:500;
            letter-spacing:.3px; color:var(--ink); line-height:1; }
        .dash-title span{ color:var(--gold); font-weight:300; }
        .dash-sub-h{ font-family:'Jost',sans-serif; font-size:9px; letter-spacing:2px; text-transform:uppercase;
            color:var(--ink-muted); margin-top:4px; }
        .dash-spacer{ flex:1; }
        .dash-back{ font-family:'Jost',sans-serif; font-size:10px; letter-spacing:1.5px; text-transform:uppercase;
            color:var(--ink-muted); text-decoration:none; transition:color .15s; }
        .dash-back:hover{ color:var(--gold); }
        .dash-status{ font-family:'Jost',sans-serif; font-size:10px; letter-spacing:1.5px; color:var(--ink-muted);
            min-width:130px; text-align:right; }

        .dash-layout{ display:flex; align-items:stretch; min-height:calc(100vh - 64px); }
        .dash-side{ width:280px; min-width:280px; background:var(--cream-dark); border-right:1px solid var(--border);
            padding:14px 0; }
        .dash-side-label{ padding:6px 16px 10px; font-family:'Jost',sans-serif; font-size:9px; font-weight:400;
            letter-spacing:2.5px; text-transform:uppercase; color:var(--ink-muted); opacity:.7; }
        .cat{ padding:10px 16px; cursor:pointer; font-family:'Cormorant Garamond',serif; font-size:16px;
            color:var(--ink-muted); display:flex; justify-content:space-between; gap:10px; align-items:center;
            border-left:2px solid transparent; transition:background .12s,color .12s; }
        .cat:hover{ background:rgba(155,45,58,.10); color:var(--gold); }
        .cat.active{ background:rgba(155,45,58,.14); color:var(--gold); border-left-color:var(--gold); }
        .cat .count{ font-family:'Jost',sans-serif; font-size:10px; color:var(--ink-muted); }

        .dash-content{ flex:1; padding:26px 30px; max-width:1080px; }
        .dash-content h2{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:24px;
            color:var(--ink); margin-bottom:4px; }
        .dash-content .sub{ font-family:'Cormorant Garamond',serif; font-size:15px; font-weight:300;
            color:var(--ink-muted); margin-bottom:18px; line-height:1.6; }

        .btn{ font-family:'Jost',sans-serif; font-size:10px; font-weight:400; letter-spacing:2.5px;
            text-transform:uppercase; border:none; cursor:pointer; transition:background .2s,border-color .2s,color .2s; }
        .btn-save{ padding:10px 32px; background:var(--gold); color:var(--ink); }
        .btn-save:hover:not(:disabled){ background:var(--gold-light); }
        .btn-save:disabled{ opacity:.35; cursor:default; }
        .btn-add{ padding:10px 26px; background:transparent; border:1px solid var(--border); color:var(--ink-soft);
            margin-bottom:18px; }
        .btn-add:hover{ border-color:var(--gold); color:var(--gold); }

        .card{ background:var(--white); border:1px solid var(--border); border-left:2px solid var(--gold-light);
            margin-bottom:12px; }
        .card.inactive{ opacity:.5; }
        .card-head{ display:flex; align-items:center; gap:12px; padding:13px 16px; cursor:pointer; }
        .card-head .chev{ color:var(--ink-muted); font-size:11px; transition:transform .15s; }
        .card.open .card-head .chev{ transform:rotate(90deg); }
        .card-head .client{ flex:1; font-family:'Cormorant Garamond',serif; font-size:17px; font-weight:400;
            color:var(--ink); }
        .card-body{ display:none; padding:4px 16px 18px; border-top:1px solid var(--border); }
        .card.open .card-body{ display:block; }

        .field{ margin-top:16px; }
        .field > label{ display:block; font-family:'Jost',sans-serif; font-size:9px; font-weight:400;
            letter-spacing:2px; text-transform:uppercase; color:var(--gold); margin-bottom:8px; }
        .bi{ display:grid; grid-template-columns:1fr auto 1fr; gap:10px; align-items:start; }
        .bi .lang{ display:block; font-family:'Jost',sans-serif; font-size:8px; letter-spacing:1.5px;
            text-transform:uppercase; color:var(--ink-muted); margin-bottom:4px; opacity:.8; }
        .dash-content input[type=text], .dash-content textarea{
            width:100%; background:var(--cream); border:1px solid var(--border); color:var(--ink);
            font-family:'Cormorant Garamond',serif; font-size:15px; font-weight:300; padding:8px 11px;
            outline:none; resize:vertical; line-height:1.55; transition:border-color .2s; }
        .dash-content input[type=text]:focus, .dash-content textarea:focus{ border-color:var(--gold-light); }
        .dash-content textarea{ min-height:62px; }
        .field.longf textarea{ min-height:130px; }
        .trcol{ display:flex; flex-direction:column; gap:6px; padding-top:18px; }
        .btn-tr{ background:transparent; border:1px solid var(--border); color:var(--ink-muted);
            font-family:'Jost',sans-serif; font-size:8px; letter-spacing:1px; text-transform:uppercase;
            padding:6px 8px; cursor:pointer; white-space:nowrap; transition:border-color .15s,color .15s; }
        .btn-tr:hover{ border-color:var(--gold); color:var(--gold); }

        .row-actions{ display:flex; align-items:center; gap:8px; }
        .switch{ display:flex; align-items:center; gap:5px; font-family:'Jost',sans-serif; font-size:9px;
            letter-spacing:1px; text-transform:uppercase; color:var(--ink-muted); }
        .switch input{ accent-color:var(--gold); cursor:pointer; }
        .iconbtn{ background:transparent; border:1px solid var(--border); color:var(--ink-muted); cursor:pointer;
            width:30px; height:30px; font-size:13px; transition:border-color .15s,color .15s,background .15s; }
        .iconbtn:hover{ border-color:var(--gold); color:var(--gold); }
        .iconbtn.del:hover{ border-color:#c0392b; color:#c0392b; background:rgba(192,57,43,.08); }

        .empty{ font-family:'Cormorant Garamond',serif; font-style:italic; color:var(--ink-muted);
            padding:30px 0; }

        .toast{ position:fixed; bottom:24px; right:24px; background:var(--white); border:1px solid var(--border);
            border-left:2px solid var(--gold-light); color:var(--ink-soft); padding:12px 20px;
            font-family:'Cormorant Garamond',serif; font-size:15px; opacity:0; transition:opacity .25s;
            pointer-events:none; z-index:50; }
        .toast.show{ opacity:1; }
        .toast.err{ border-left-color:#c0392b; color:var(--red-accent); }

        @@media (max-width:768px){
            .dash-layout{ flex-direction:column; }
            .dash-side{ width:100%; min-width:0; border-right:none; border-bottom:1px solid var(--border);
                display:flex; flex-wrap:wrap; padding:8px; }
            .cat{ border-left:none; }
            .dash-side-label{ width:100%; }
            .dash-content{ padding:20px 16px; }
            .bi{ grid-template-columns:1fr; }
            .trcol{ flex-direction:row; padding-top:0; }
        }
    </style>
</head>
<body>
    <div class="dash-topbar">
        <div class="logo-mark">
            <svg viewBox="0 0 48 48" fill="none">
                <rect x="0.5" y="0.5" width="47" height="47" stroke="#9B2D3A" stroke-width="1" fill="none"/>
                <line x1="0" y1="0" x2="7" y2="0" stroke="#C4556A" stroke-width="1.2"/>
                <line x1="0" y1="0" x2="0" y2="7" stroke="#C4556A" stroke-width="1.2"/>
                <line x1="48" y1="0" x2="41" y2="0" stroke="#C4556A" stroke-width="1.2"/>
                <line x1="48" y1="0" x2="48" y2="7" stroke="#C4556A" stroke-width="1.2"/>
                <line x1="0" y1="48" x2="7" y2="48" stroke="#C4556A" stroke-width="1.2"/>
                <line x1="0" y1="48" x2="0" y2="41" stroke="#C4556A" stroke-width="1.2"/>
                <line x1="48" y1="48" x2="41" y2="48" stroke="#C4556A" stroke-width="1.2"/>
                <line x1="48" y1="48" x2="48" y2="41" stroke="#C4556A" stroke-width="1.2"/>
                <text x="25" y="22" font-family="Cormorant Garamond, serif" font-size="13" font-weight="500"
                      fill="#9B2D3A" text-anchor="middle" letter-spacing="2">ERA</text>
                <line x1="10" y1="27" x2="38" y2="27" stroke="#C4556A" stroke-width="0.6" opacity="0.6"/>
                <text x="26" y="38" font-family="Jost, sans-serif" font-size="8" font-weight="300"
                      fill="#7a7060" text-anchor="middle" letter-spacing="4">AI</text>
            </svg>
        </div>
        <div>
            <div class="dash-title">Portofoliu de proiecte <span>ERA</span></div>
            <div class="dash-sub-h">Track record · editor</div>
        </div>
        <div class="dash-spacer"></div>
        <a class="dash-back" href="/">← Înapoi la aplicație</a>
        <div class="dash-status" id="status"></div>
        <button class="btn btn-save" id="saveBtn" onclick="saveAll()" disabled>Salvează</button>
    </div>

    <div class="dash-layout">
        <div class="dash-side">
            <div class="dash-side-label">Categorii</div>
            <div id="sidebar"></div>
        </div>
        <div class="dash-content">
            <h2 id="catTitle">—</h2>
            <div class="sub">Adăugați, editați, reordonați sau ascundeți proiectele firmei. Textul lung apare în
                Prezentarea Generală, iar textul scurt în Ofertă.</div>
            <button class="btn btn-add" onclick="addProject()">+ Proiect nou</button>
            <div id="cards"></div>
        </div>
    </div>

    <div class="toast" id="toast"></div>

    <script>
    let DB = { categories: [], projects: [] };
    let selectedCat = null;
    let dirty = false;

    function setDirty(v){ dirty = v; const b=document.getElementById('saveBtn');
        b.disabled = !v; document.getElementById('status').textContent = v ? 'Modificări nesalvate' : ''; }

    function toast(msg, isErr){ const t=document.getElementById('toast'); t.textContent=msg;
        t.className='toast show'+(isErr?' err':''); setTimeout(()=>t.className='toast',2600); }

    function catName(id){ const c=DB.categories.find(c=>c.id===id); return c? c.name.ro : id; }

    async function load(){
        const r = await fetch('/api/projects');
        if(!r.ok){ toast('Eroare la încărcare', true); return; }
        DB = await r.json();
        if(!selectedCat && DB.categories.length) selectedCat = DB.categories[0].id;
        renderSidebar(); renderCards(); setDirty(false);
    }

    function projectsOf(cat){
        return DB.projects.filter(p=>p.category===cat).sort((a,b)=>(a.order||0)-(b.order||0));
    }

    function renderSidebar(){
        const sb=document.getElementById('sidebar'); sb.innerHTML='';
        DB.categories.forEach(c=>{
            const n=projectsOf(c.id).length;
            const div=document.createElement('div');
            div.className='cat'+(c.id===selectedCat?' active':'');
            div.innerHTML=`<span>${c.name.ro}</span><span class="count">${n}</span>`;
            div.onclick=()=>{ selectedCat=c.id; renderSidebar(); renderCards(); };
            sb.appendChild(div);
        });
    }

    function esc(s){ return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    function renderCards(){
        document.getElementById('catTitle').textContent = catName(selectedCat);
        const wrap=document.getElementById('cards'); wrap.innerHTML='';
        const list=projectsOf(selectedCat);
        if(!list.length){ wrap.innerHTML='<div class="empty">Niciun proiect în această categorie. Adăugați unul.</div>'; return; }
        list.forEach(p=>wrap.appendChild(cardEl(p)));
    }

    function cardEl(p){
        const card=document.createElement('div');
        card.className='card'+(p.active?'':' inactive')+(p._open?' open':'');
        const head=document.createElement('div'); head.className='card-head';
        head.innerHTML=`<span class="chev">▶</span><span class="client">${esc(p.client.ro||p.client.en)||'(fără nume)'}</span>`;
        const actions=document.createElement('div'); actions.className='row-actions';
        actions.innerHTML=`
            <label class="switch" title="Vizibil în documente">
              <input type="checkbox" ${p.active?'checked':''} onchange="toggleActive('${p.id}',this.checked)"/> vizibil
            </label>
            <button class="iconbtn" title="Mută sus" onclick="move('${p.id}',-1)">↑</button>
            <button class="iconbtn" title="Mută jos" onclick="move('${p.id}',1)">↓</button>
            <button class="iconbtn del" title="Șterge" onclick="del('${p.id}')">✕</button>`;
        head.appendChild(actions);
        head.onclick=(e)=>{ if(e.target.closest('.row-actions'))return; p._open=!p._open; card.classList.toggle('open'); };

        const body=document.createElement('div'); body.className='card-body';
        body.appendChild(biField(p,'client','Client', false));
        body.appendChild(biField(p,'short','Text scurt (Ofertă)', true));
        body.appendChild(biField(p,'long','Text lung (Prezentare Generală)', true, true));
        card.appendChild(head); card.appendChild(body);
        return card;
    }

    function biField(p, key, label, multiline, isLong){
        const f=document.createElement('div'); f.className='field'+(isLong?' longf':'');
        const tag = multiline ? 'textarea' : 'input';
        const ie = multiline ? '' : 'type="text"';
        f.innerHTML=`<label>${label}</label>
          <div class="bi">
            <div><span class="lang">English</span>
              <${tag} ${ie} oninput="upd('${p.id}','${key}','en',this.value)">${multiline?esc(p[key].en):''}</${tag}></div>
            <div class="trcol">
              <button class="btn-tr" onclick="tr('${p.id}','${key}','ro')" title="Traduce EN→RO">EN→RO</button>
              <button class="btn-tr" onclick="tr('${p.id}','${key}','en')" title="Traduce RO→EN">RO→EN</button>
            </div>
            <div><span class="lang">Română</span>
              <${tag} ${ie} oninput="upd('${p.id}','${key}','ro',this.value)">${multiline?esc(p[key].ro):''}</${tag}></div>
          </div>`;
        if(!multiline){
            const ins=f.querySelectorAll('input');
            ins[0].value=p[key].en||''; ins[1].value=p[key].ro||'';
        }
        return f;
    }

    function find(id){ return DB.projects.find(p=>p.id===id); }
    function upd(id,key,lang,val){ const p=find(id); if(!p)return; p[key][lang]=val; setDirty(true); }
    function toggleActive(id,v){ const p=find(id); if(p){ p.active=v; setDirty(true); renderCards(); } }

    function del(id){ const p=find(id); if(!p)return;
        if(!confirm('Ștergeți acest proiect?'))return;
        DB.projects=DB.projects.filter(x=>x.id!==id); setDirty(true); renderSidebar(); renderCards(); }

    function move(id,dir){
        const p=find(id); if(!p)return;
        const list=projectsOf(p.category);
        const i=list.findIndex(x=>x.id===id); const j=i+dir;
        if(j<0||j>=list.length)return;
        const a=list[i], b=list[j]; const ao=a.order||0, bo=b.order||0; a.order=bo; b.order=ao;
        setDirty(true); renderCards();
    }

    function addProject(){
        const list=projectsOf(selectedCat);
        const maxOrder=list.reduce((m,p)=>Math.max(m,p.order||0),0);
        DB.projects.push({ id:'new-'+Date.now(), category:selectedCat, active:true, order:maxOrder+1,
                   client:{en:'',ro:''}, short:{en:'',ro:''}, long:{en:'',ro:''}, _open:true });
        setDirty(true); renderSidebar(); renderCards(); window.scrollTo({top:0,behavior:'smooth'});
    }

    async function tr(id,key,target){
        const p=find(id); if(!p)return;
        const source = target==='ro' ? 'en' : 'ro';
        const text=p[key][source];
        if(!text || !text.trim()){ toast('Nimic de tradus în limba sursă', true); return; }
        toast('Se traduce…');
        try{
            const r=await fetch('/api/translate',{method:'POST',headers:{'Content-Type':'application/json'},
                body:JSON.stringify({text, target})});
            const d=await r.json();
            if(!r.ok) throw new Error(d.error||d.detail||'eroare');
            p[key][target]=d.translation; p._open=true; setDirty(true); renderCards();
            toast('Tradus');
        }catch(e){ toast('Eroare la traducere: '+e.message, true); }
    }

    async function saveAll(){
        document.getElementById('status').textContent='Se salvează…';
        const projects=DB.projects.map(({_open,...p})=> (String(p.id).startsWith('new-')? (({id,...rest})=>rest)(p) : p));
        try{
            const r=await fetch('/api/projects',{method:'PUT',headers:{'Content-Type':'application/json'},
                body:JSON.stringify({projects})});
            const d=await r.json();
            if(!r.ok) throw new Error(d.error||d.detail||'eroare');
            toast('Salvat cu succes'); await load();
        }catch(e){ document.getElementById('status').textContent='Eroare'; toast('Eroare la salvare: '+e.message, true); }
    }

    window.addEventListener('beforeunload', e=>{ if(dirty){ e.preventDefault(); e.returnValue=''; } });
    load();
    </script>
</body>
</html>
